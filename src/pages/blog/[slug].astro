---
import BlogPost from '../../layouts/BlogPost.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '../../lib/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('blog-en', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const minutes = readingTime(post.body);

// Surface up to 3 related posts (shared tag, exclude self)
const all = await getCollection('blog-en', ({ data }) => !data.draft);
const myTags = new Set(post.data.tags ?? []);
const related = all
  .filter(p => p.slug !== post.slug && (p.data.tags ?? []).some(t => myTags.has(t)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  tags={post.data.tags}
  readingTimeMin={minutes}
>
  <Content />

  {related.length > 0 && (
    <aside class="not-prose mt-16 pt-10" style="border-top:2px solid var(--fg)">
      <span class="section-label mb-5 block">// related articles</span>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {related.map(p => <BlogCard post={p} />)}
      </div>
    </aside>
  )}
</BlogPost>
