---
import Base from '../../layouts/Base.astro';
import Lesson from '../../components/Lesson.astro';
import { lessons, getLesson } from '../../data/lessons';

export function getStaticPaths() {
  return lessons.map((l) => ({ params: { slug: l.slug } }));
}

const { slug } = Astro.params;
const lesson = getLesson(slug!)!;

// After a lesson, point to the next one in the path (beginner → intermediate
// → advanced, by order), so the whole curriculum plays as one sequence.
const levelRank = { beginner: 0, intermediate: 1, advanced: 2 } as const;
const sequence = [...lessons].sort(
  (a, b) => levelRank[a.level] - levelRank[b.level] || a.order - b.order,
);
const nextLesson = sequence[sequence.findIndex((l) => l.slug === lesson.slug) + 1];
const nextStep = nextLesson
  ? {
      href: `/learn/${nextLesson.slug}`,
      label: nextLesson.level === lesson.level ? 'Next lesson' : `Next: ${nextLesson.pathway ?? nextLesson.title}`,
    }
  : undefined;
---

<Base
  title={lesson.title}
  description={lesson.intro}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">

    <div class="flex items-center justify-between flex-wrap gap-3 mb-8">
      <a
        href="/guides"
        class="ghost-btn group inline-flex items-center gap-2 font-mono text-[12px] px-4 h-10 rounded-[4px]"
      >
        <span class="transition-transform duration-200 group-hover:-translate-x-0.5">←</span>
        Guidebook
      </a>
      <span class="font-mono text-[11px]" style="color:var(--fg-muted);letter-spacing:0.06em">
        Interactive lesson
      </span>
    </div>

    <Lesson
      lesson={lesson}
      nextHref={nextStep?.href}
      nextLabel={nextStep?.label}
      backHref="/guides"
    />

  </div>
</Base>
