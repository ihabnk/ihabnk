---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Not Found" description="Page not found">
  <div class="relative min-h-[82vh] flex flex-col items-center justify-center px-4 text-center overflow-hidden">

    <!-- Amber orb glow behind 404 -->
    <div
      class="absolute pointer-events-none"
      style="width:600px;height:600px;border-radius:50%;background:var(--accent-glow);filter:blur(80px);top:50%;left:50%;transform:translate(-50%,-55%);z-index:0"
      aria-hidden="true"
    ></div>

    <!-- Giant 404 -->
    <div class="relative z-10 select-none" style="transform:rotate(-3deg)">
      <span
        class="font-bold leading-none block"
        style="font-family:var(--font-display);font-size:clamp(120px,18vw,240px);color:var(--accent-text);line-height:1"
      >404</span>
    </div>

    <!-- Section label -->
    <span class="section-label mt-6 mb-4 relative z-10">// not found</span>

    <!-- Headline -->
    <h1
      class="font-bold mb-4 relative z-10"
      style="font-family:var(--font-display);font-size:clamp(24px,4vw,40px);color:var(--fg)"
    >Page not found</h1>

    <!-- Body copy -->
    <p class="text-[15px] leading-relaxed mb-10 max-w-sm relative z-10" style="color:var(--fg-mid)">
      Steps to reproduce: click a link. Expected: a page. Actual: this.
      Severity: low — everything you came for is still one click away.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-3 justify-center relative z-10">
      <a href="/" class="btn-primary inline-flex items-center gap-2 font-bold text-sm px-6 h-11 rounded-[4px]">
        ← Back home
      </a>
      <a href="/blog" class="ghost-btn inline-flex items-center gap-2 text-sm px-6 h-11 rounded-[4px]">
        All articles
      </a>
    </div>

  </div>
</Base>
