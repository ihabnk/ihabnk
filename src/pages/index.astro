---
import Base from '../layouts/Base.astro';
import HeroVisual from '../components/HeroVisual.astro';
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { fetchRepos } from '../lib/github';

const posts = (await getCollection('blog-en', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const repos = await fetchRepos('ihabnk');
---

<Base title="ihabnk" description="QA Engineer turned AI Product builder">

  <!-- ═══════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-[780px] flex items-center overflow-hidden" style="background:var(--bg-page)">

    <HeroVisual />

    <div class="relative z-10 w-full max-w-5xl mx-auto px-4 sm:px-6 py-20">
      <div class="max-w-[600px]">

        <span class="section-label mb-5 block tracking-[0.08em]">// software engineer</span>

        <h1 class="font-bold leading-[1.0] mb-5" style="font-size:clamp(40px,9vw,72px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em">
          QA Engineering → AI Product
        </h1>

        <p class="text-[17px] leading-[1.7] mb-6 max-w-[480px]" style="color:var(--fg-mid)">
          I build AI-augmented quality systems and ship digital products that actually work.
        </p>

        <!-- Code snippet card -->
        <div class="card-brutal mb-8 inline-block px-5 py-4" style="background:var(--bg-card)">
          <div class="font-mono text-[13px] line-through" style="color:var(--pop-red)"># before: manual QA → delayed releases</div>
          <div class="font-mono text-[13px] mt-1" style="color:var(--accent-text)"># after:  AI-augmented quality systems that ship</div>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href="/blog" class="btn-primary inline-flex items-center gap-2 font-bold text-sm px-6 h-11 rounded-[4px]">
            Read articles
          </a>
          <a href="#projects" class="ghost-btn inline-flex items-center gap-2 text-sm px-6 h-11 rounded-[4px]">
            Projects
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       RECENT ARTICLES
       ═══════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-20">
    <div class="glow-sep mb-14"></div>

    <div class="flex items-end justify-between mb-10">
      <div>
        <span class="section-label mb-2">// articles</span>
        <h2 class="font-bold" style="font-size:clamp(32px,4vw,44px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1">Recent Articles</h2>
      </div>
      <a href="/blog" class="font-mono text-[11px] transition-opacity duration-200 hover:opacity-70" style="color:var(--accent-text)">
        All articles →
      </a>
    </div>

    {posts.length === 0 ? (
      <p class="font-mono text-sm" style="color:var(--fg-muted)">No posts yet.</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, i) => <BlogCard {post} animate stagger={Math.min(i + 1, 4) as 1|2|3|4} />)}
      </div>
    )}
  </section>

  <!-- ═══════════════════════════════════════════
       PROJECTS
       ═══════════════════════════════════════════ -->
  <section id="projects" class="max-w-5xl mx-auto px-4 sm:px-6 py-20">
    <div class="glow-sep mb-14"></div>

    <div class="flex items-end justify-between mb-10">
      <div>
        <span class="section-label mb-2">// projects</span>
        <h2 class="font-bold" style="font-size:clamp(32px,4vw,44px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1">Projects</h2>
      </div>
      <a
        href="https://github.com/ihabnk"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-[11px] transition-opacity duration-200 hover:opacity-70"
        style="color:var(--accent-text)"
      >GitHub →</a>
    </div>

    {repos.length === 0 ? (
      <p class="font-mono text-sm" style="color:var(--fg-muted)">// no repos loaded — visit GitHub directly</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {repos.map(repo => <ProjectCard {repo} />)}
      </div>
    )}
  </section>

  <!-- ═══════════════════════════════════════════
       SUPPORT CTA (compact)
       ═══════════════════════════════════════════ -->
  <section
    id="support"
    class="py-10 px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-center gap-4 text-center"
    style="background:var(--bg-surface);border-top:2px solid var(--fg);border-bottom:2px solid var(--fg)"
  >
    <p class="text-[14px] font-mono" style="color:var(--fg-mid)">
      If my work helped you →
    </p>
    <a
      href="https://www.buymeacoffee.com/ihabnk"
      target="_blank"
      rel="noopener noreferrer"
      class="ghost-btn inline-flex items-center gap-2 font-mono text-[12px] px-5 h-9 rounded-[4px]"
    >
      Buy me a coffee
    </a>
  </section>

</Base>

<script>
  const io = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('fade-up'); io.unobserve(e.target); }
    }),
    { threshold: 0.06 }
  );
  document.querySelectorAll('[data-tags]').forEach(el => io.observe(el));
</script>
