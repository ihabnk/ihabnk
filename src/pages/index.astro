<script>
  // Hero text parallax — text drifts up at 0.22× scroll speed, capped at 80px.
  // Opacity floor of 0.85 so the hero never goes dim enough to look "ghosted".
  (() => {
    type W = Window & { __heroParallaxBound?: boolean };
    const w = window as W;

    let ticking = false;
    const apply = () => {
      const el = document.querySelector<HTMLElement>('.hero-text-parallax');
      if (!el) return;
      const sy = window.scrollY;
      const y = Math.min(sy * 0.22, 80);
      const opacity = Math.max(0.85, 1 - sy / 1400);
      el.style.transform = `translate3d(0, ${-y}px, 0)`;
      el.style.opacity = String(opacity);
      ticking = false;
    };

    if (!w.__heroParallaxBound) {
      w.__heroParallaxBound = true;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(apply);
        }
      }, { passive: true });
    }

    apply();
    document.addEventListener('astro:page-load', apply);
  })();
</script>
