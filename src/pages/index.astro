---
import Base from '../layouts/Base.astro';
import HeroVisual from '../components/HeroVisual.astro';
import BlogCard from '../components/BlogCard.astro';
import ReviewArt from '../components/ReviewArt.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog-en', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Pick a featured comparison review to showcase on the home page
const allReviews = await getCollection('reviews-en', ({ data }) => !data.draft);

// Hero stats (kept honest: live counts of content, fixed "10y QA")
const heroStats = [
  { value: '10+ y', label: 'qa' },
  { value: String(allPosts.length), label: 'articles' },
  { value: String(allReviews.length), label: 'reviews' },
  { value: 'gmt+3', label: 'tz' },
];
const featuredReview =
  allReviews
    .filter((r) => r.data.kind === 'comparison' && r.data.featured)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0]
  ?? allReviews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0];

// "Now" line — what's currently on the bench
const now = {
  date: '2026-06-19',
  building: 'a self-testing agent that grades its own evals',
  shipping: 'the new ReviewArt + bidirectional scroll-reveal',
};

const STOAT_URL = 'https://stoat.chat/server/01KRX7GT1KEA2BK47257B1XGP1/channel/01KRX7GT1KB53TTBX7BTKZ4529';
---

<Base title="ihabnk" description="QA Engineer turned AI Product builder">

  <!-- ═══════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-[520px] sm:min-h-[640px] lg:min-h-[720px] flex items-center overflow-hidden" style="background:var(--bg-page)">

    <HeroVisual />

    <div class="relative z-10 w-full max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
      <div class="max-w-[600px] hero-text-parallax">

        <!-- Status chip: pulsing live dot + brand line -->
        <div class="hero-status mb-5">
          <span class="hero-status-dot" aria-hidden="true"></span>
          <span class="hero-status-label">Shipping</span>
          <span class="hero-status-sep">·</span>
          <span class="hero-status-meta">QA engineer turned AI builder</span>
        </div>

        <h1 class="font-bold leading-[1.0] mb-4 hero-title" style="font-size:clamp(40px,9vw,72px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em">
          <span class="hero-title-word">QA Engineering</span>
          <span class="hero-title-arrow">→</span>
          <span class="hero-title-word hero-title-word-accent">AI Product</span>
        </h1>

        <p class="text-[17px] leading-[1.6] mb-5 max-w-[480px]" style="color:var(--fg-mid)">
          I build AI-augmented quality systems and ship digital products that actually work.
        </p>

        <!-- Code snippet card -->
        <div class="card-brutal mb-6 inline-block max-w-full px-4 py-3 sm:px-5 sm:py-4" style="background:var(--bg-card)">
          <div class="font-mono text-[12px] sm:text-[13px] line-through break-words" style="color:var(--pop-red)"># before: manual QA → delayed releases</div>
          <div class="font-mono text-[12px] sm:text-[13px] mt-1 break-words" style="color:var(--accent-text)"># after:  AI-augmented quality systems that ship</div>
        </div>

        <div class="flex flex-wrap gap-3 mb-7">
          <a href="/blog" class="btn-primary inline-flex items-center gap-2 font-bold text-sm px-6 h-11 rounded-[4px]">
            Read articles
          </a>
          <a href="/reviews" class="ghost-btn inline-flex items-center gap-2 text-sm px-6 h-11 rounded-[4px]">
            Reviews
          </a>
        </div>

        <!-- Stats strip — live counts of content + tz -->
        <ul class="hero-stats" aria-label="At-a-glance stats">
          {heroStats.map((s) => (
            <li class="hero-stat">
              <span class="hero-stat-value">{s.value}</span>
              <span class="hero-stat-label">{s.label}</span>
            </li>
          ))}
        </ul>

      </div>
    </div>

    <!-- Scroll cue at the bottom of the hero -->
    <a class="hero-scroll-cue" href="#articles" aria-label="Scroll to articles">
      <span class="hero-scroll-cue-label">scroll</span>
      <span class="hero-scroll-cue-arrow" aria-hidden="true">
        <svg viewBox="0 0 16 24" xmlns="http://www.w3.org/2000/svg">
          <rect x="0.75" y="0.75" width="14.5" height="22.5" rx="7" style="fill:none;stroke:currentColor;stroke-width:1.5"/>
          <line x1="8" y1="6" x2="8" y2="11" style="stroke:currentColor;stroke-width:1.8;stroke-linecap:round"/>
        </svg>
      </span>
    </a>
  </section>

  <!-- ═══════════════════════════════════════════
       PRINCIPLES STRIP — three brutalist glyphs
       ═══════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-10 sm:pt-14" aria-label="Working principles">
    <div class="principles-strip">

      <!-- BUILD -->
      <div class="principle-card reveal stagger-1">
        <svg viewBox="0 0 80 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="6"  y="22" width="22" height="22" rx="2" style="fill:var(--bg-surface);stroke:var(--fg);stroke-width:2"/>
          <rect class="pr-pulse" x="29" y="10" width="22" height="34" rx="2" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <rect x="52" y="30" width="22" height="14" rx="2" style="fill:var(--bg-surface);stroke:var(--fg);stroke-width:2"/>
          <line x1="6" y1="46" x2="74" y2="46" style="stroke:var(--fg);stroke-width:2"/>
        </svg>
        <div class="principle-kicker">// 01</div>
        <div class="principle-title">Build</div>
        <div class="principle-sub">small, sturdy, in public</div>
      </div>

      <!-- EVAL -->
      <div class="principle-card reveal stagger-2">
        <svg viewBox="0 0 80 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <line x1="10" y1="14" x2="10" y2="46" style="stroke:var(--fg);stroke-width:2"/>
          <line x1="10" y1="46" x2="72" y2="46" style="stroke:var(--fg);stroke-width:2"/>
          <rect x="18" y="30" width="8" height="14" style="fill:none;stroke:var(--fg);stroke-width:2"/>
          <rect x="30" y="22" width="8" height="22" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <rect x="42" y="26" width="8" height="18" style="fill:none;stroke:var(--fg);stroke-width:2"/>
          <rect class="pr-pulse" x="54" y="18" width="8" height="26" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <polyline class="pr-check" points="46,10 52,16 64,4"
                    style="fill:none;stroke:var(--accent-text);stroke-width:2.4;stroke-linecap:round;stroke-linejoin:round;stroke-dasharray:32;stroke-dashoffset:32"/>
        </svg>
        <div class="principle-kicker">// 02</div>
        <div class="principle-title">Eval</div>
        <div class="principle-sub">measure before you ship</div>
      </div>

      <!-- SHIP -->
      <div class="principle-card reveal stagger-3">
        <svg viewBox="0 0 80 60" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="6"  y="22" width="20" height="16" rx="2" style="fill:var(--bg-surface);stroke:var(--fg);stroke-width:2"/>
          <rect class="pr-pulse" x="30" y="22" width="20" height="16" rx="2" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <line class="pr-flow" x1="50" y1="30" x2="64" y2="30" style="stroke:var(--fg);stroke-width:2;stroke-dasharray:4 3"/>
          <polygon points="64,24 74,30 64,36" style="fill:var(--accent-text)"/>
          <line x1="6"  y1="46" x2="74" y2="46" style="stroke:var(--fg);stroke-width:2;stroke-dasharray:4 3"/>
        </svg>
        <div class="principle-kicker">// 03</div>
        <div class="principle-title">Ship</div>
        <div class="principle-sub">production &gt; prototype</div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       RECENT ARTICLES
       ═══════════════════════════════════════════ -->
  <section id="articles" class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16 scroll-mt-24">
    <div class="glow-sep mb-8 sm:mb-10"></div>

    <div class="flex items-end justify-between mb-6 sm:mb-8">
      <div>
        <span class="section-label mb-2 reveal-soft">// articles</span>
        <h2 class="font-bold reveal-soft reveal-pop" style="font-size:clamp(32px,4vw,44px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1">Recent Articles</h2>
      </div>
      <a href="/blog" class="font-mono text-[11px] transition-opacity duration-200 hover:opacity-70" style="color:var(--accent-text)">
        All articles →
      </a>
    </div>

    {posts.length === 0 ? (
      <p class="font-mono text-sm" style="color:var(--fg-muted)">No posts yet.</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, i) => <BlogCard {post} animate stagger={Math.min(i + 1, 4) as 1|2|3|4} />)}
      </div>
    )}
  </section>

  <!-- ═══════════════════════════════════════════
       FEATURED REVIEW
       ═══════════════════════════════════════════ -->
  {featuredReview && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-12 sm:pb-16" aria-label="Featured comparison">
      <div class="glow-sep mb-8 sm:mb-10"></div>

      <div class="flex items-end justify-between mb-6 sm:mb-8">
        <div>
          <span class="section-label mb-2 reveal-soft">// featured comparison</span>
          <h2 class="font-bold reveal-soft reveal-pop" style="font-size:clamp(32px,4vw,44px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1">
            Head-to-head
          </h2>
        </div>
        <a href="/reviews" class="font-mono text-[11px] transition-opacity duration-200 hover:opacity-70" style="color:var(--accent-text)">
          All reviews →
        </a>
      </div>

      <a
        href={`/reviews/${featuredReview.slug}`}
        class="featured-review-card card-brutal group block relative overflow-hidden reveal"
        style="background:var(--bg-card)"
      >
        <div class="featured-review-grid">
          <div class="featured-review-art">
            <ReviewArt slug={featuredReview.slug} variant="hero" kind={featuredReview.data.kind} tools={featuredReview.data.tools ?? []} />
          </div>

          <div class="featured-review-body">
            <div class="flex items-center gap-2 flex-wrap mb-3">
              <span
                class="font-mono text-[10px] px-[10px] py-[3px] rounded-[3px] font-bold"
                style="background:var(--accent);color:var(--on-accent);letter-spacing:0.05em"
              >VS</span>
              {(featuredReview.data.tools ?? []).map((t, i) => (
                <>
                  {i > 0 && <span class="font-mono text-[10px]" style="color:var(--fg-muted)">vs</span>}
                  <span
                    class="font-mono text-[10px] px-[8px] py-[2px] rounded-[3px]"
                    style="border:1.5px solid var(--border-mid);color:var(--fg);background:var(--bg-page);letter-spacing:0.04em"
                  >{t}</span>
                </>
              ))}
            </div>

            <h3 class="font-bold leading-[1.18] mb-3" style="font-size:clamp(22px,3.4vw,32px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em">
              {featuredReview.data.title}
            </h3>

            {featuredReview.data.verdict && (
              <p class="text-[15px] leading-[1.65] mb-4 line-clamp-3" style="color:var(--fg-mid)">
                {featuredReview.data.verdict}
              </p>
            )}

            <span class="font-mono text-[11px] font-bold inline-flex items-center gap-2" style="color:var(--accent-text)">
              Read the comparison
              <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
            </span>
          </div>
        </div>
      </a>
    </section>
  )}

  <!-- ═══════════════════════════════════════════
       COMMUNITY
       ═══════════════════════════════════════════ -->
  <section id="community" class="max-w-5xl mx-auto px-4 sm:px-6 pb-12 sm:pb-16">
    <div class="glow-sep mb-8 sm:mb-10"></div>

    <div
      class="card-brutal community-card relative overflow-hidden p-6 sm:p-8"
      style="background:var(--bg-card)"
    >
      <!-- Decorative accent glow in the top-right -->
      <div
        aria-hidden="true"
        class="absolute pointer-events-none"
        style="top:-60px;right:-60px;width:280px;height:280px;background:radial-gradient(circle at center, var(--accent-glow), transparent 65%)"
      ></div>

      <div class="relative flex flex-col gap-5 lg:flex-row lg:items-center lg:gap-8">

        <div class="flex-1">
          <span class="section-label mb-3 block reveal-soft">// community</span>
          <h2
            class="font-bold mb-3 reveal-soft reveal-pop"
            style="font-size:clamp(26px,3.6vw,38px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1.08"
          >Build alongside other QA &amp; AI engineers</h2>
          <p
            class="text-[16px] leading-[1.55] max-w-[560px] reveal-soft"
            style="color:var(--fg-mid)"
          >
            I run a Stoat channel where I share works-in-progress, swap tooling
            notes, and answer questions from people moving from QA into AI
            product work. Pull up a chair — it's quiet, useful, and zero noise.
          </p>

          <!-- Trio of fine-print value props -->
          <ul class="mt-4 flex flex-wrap gap-x-5 gap-y-2 font-mono text-[11px]" style="color:var(--fg-muted)">
            <li><span style="color:var(--accent-text);font-weight:700">·</span> Tool deep-dives</li>
            <li><span style="color:var(--accent-text);font-weight:700">·</span> Code review threads</li>
            <li><span style="color:var(--accent-text);font-weight:700">·</span> Career questions, answered</li>
          </ul>
        </div>

        <div class="flex-shrink-0">
          <a
            href={STOAT_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary inline-flex items-center gap-2 font-bold text-sm px-6 h-12 rounded-[4px]"
          >
            Join the channel
            <span aria-hidden="true">↗</span>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       NOW — single-line status sticker
       ═══════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-16" aria-label="Currently">
    <div class="now-card reveal">
      <div class="now-kicker">
        <span class="now-dot" aria-hidden="true"></span>
        <span class="now-label">// now</span>
        <time class="now-date">{now.date}</time>
      </div>
      <div class="now-rows">
        <div class="now-row">
          <span class="now-tag">building</span>
          <span class="now-text">{now.building}</span>
        </div>
        <div class="now-row">
          <span class="now-tag">shipping</span>
          <span class="now-text">{now.shipping}</span>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  .principles-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  .principle-card {
    border: 2px solid var(--fg);
    border-radius: 4px;
    background: var(--bg-card);
    box-shadow: 4px 4px 0 var(--fg);
    padding: 14px 16px 12px;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }
  .principle-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--fg);
  }
  .principle-card:hover .pr-pulse  { animation-duration: 1.2s; }
  .principle-card:hover .pr-flow   { animation-duration: 0.7s; }

  /* Ambient principle-strip animation grammar */
  .pr-pulse {
    transform-box: fill-box;
    transform-origin: center;
    animation: pr-pulse 2.6s ease-in-out infinite;
  }
  @keyframes pr-pulse {
    0%, 100% { transform: scale(1);    opacity: 1; }
    50%      { transform: scale(1.06); opacity: 0.82; }
  }
  .pr-check { animation: pr-draw 3.6s ease-in-out infinite; }
  @keyframes pr-draw {
    0%       { stroke-dashoffset: 32; }
    40%, 70% { stroke-dashoffset: 0;  }
    100%     { stroke-dashoffset: 32; }
  }
  .pr-flow { animation: pr-flow 1.4s linear infinite; }
  @keyframes pr-flow {
    to { stroke-dashoffset: -14; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pr-pulse, .pr-check, .pr-flow,
    .principle-card { animation: none !important; transition: none !important; }
    .pr-check { stroke-dashoffset: 0; }
  }
  .principle-card svg {
    display: block;
    width: 64px;
    height: 48px;
    margin-bottom: 6px;
  }
  .principle-kicker {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--fg-muted);
    letter-spacing: 0.08em;
  }
  .principle-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--fg);
    line-height: 1.1;
    margin-top: 2px;
  }
  .principle-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-mid);
    margin-top: 4px;
  }
  @media (max-width: 700px) {
    .principles-strip {
      grid-template-columns: 1fr;
      gap: 10px;
    }
    .principle-card { padding: 12px 14px; }
  }

  /* ───────────────────────────────────────────────────────────
     FEATURED REVIEW CALLOUT — big two-column showcase card
     ─────────────────────────────────────────────────────────── */
  .featured-review-card {
    padding: 0;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .featured-review-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 7px 7px 0 var(--fg);
  }
  .featured-review-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 0;
    align-items: stretch;
  }
  .featured-review-art {
    border-right: 2px solid var(--fg);
    overflow: hidden;
  }
  .featured-review-art .review-art {
    border: none;
    border-radius: 0;
    width: 100%;
    height: 100%;
    aspect-ratio: auto;
    margin: 0;
    box-shadow: none;
  }
  .featured-review-body {
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media (max-width: 760px) {
    .featured-review-grid { grid-template-columns: 1fr; }
    .featured-review-art {
      border-right: none;
      border-bottom: 2px solid var(--fg);
      aspect-ratio: 16 / 9;
    }
    .featured-review-body { padding: 22px 22px; }
  }

  /* ───────────────────────────────────────────────────────────
     NOW STATUS STICKER — single-line "currently" card
     ─────────────────────────────────────────────────────────── */
  .now-card {
    position: relative;
    border: 2px solid var(--fg);
    border-radius: 4px;
    background: var(--bg-card);
    box-shadow: 4px 4px 0 var(--fg);
    padding: 16px 22px;
    display: flex;
    align-items: center;
    gap: 26px;
    flex-wrap: wrap;
  }
  .now-kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .now-dot {
    width: 9px;
    height: 9px;
    background: var(--accent);
    border-radius: 50%;
    border: 1.5px solid var(--fg);
    animation: now-dot-pulse 1.8s ease-in-out infinite;
  }
  @keyframes now-dot-pulse {
    0%, 100% { transform: scale(1);     box-shadow: 0 0 0 0 var(--accent-glow); }
    50%      { transform: scale(1.18);  box-shadow: 0 0 0 8px transparent; }
  }
  .now-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--accent-text);
    letter-spacing: 0.06em;
  }
  .now-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
    letter-spacing: 0.04em;
  }
  .now-rows {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1 1 auto;
    min-width: 0;
  }
  .now-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    min-width: 0;
  }
  .now-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    flex-shrink: 0;
    min-width: 64px;
  }
  .now-text {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--fg);
    line-height: 1.5;
  }
  @media (max-width: 640px) {
    .now-card { gap: 14px; padding: 14px 18px; }
    .now-tag  { min-width: 52px; }
  }

  /* Parallax target: smooth GPU-friendly transform */
  .hero-text-parallax {
    will-change: transform, opacity;
  }

  /* ───────────────────────────────────────────────────────────
     HERO — status chip, title animation, stats strip, scroll cue
     ─────────────────────────────────────────────────────────── */
  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px 6px 10px;
    border: 1.5px solid var(--fg);
    border-radius: 4px;
    background: var(--bg-card);
    box-shadow: 3px 3px 0 var(--fg);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--fg);
  }
  .hero-status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent-glow);
    animation: hero-status-pulse 1.8s ease-in-out infinite;
  }
  @keyframes hero-status-pulse {
    0%, 100% { transform: scale(1);   box-shadow: 0 0 0 0   var(--accent-glow); }
    50%      { transform: scale(1.2); box-shadow: 0 0 0 10px transparent; }
  }
  .hero-status-label {
    font-weight: 700;
    color: var(--accent-text);
    text-transform: uppercase;
  }
  .hero-status-sep   { color: var(--fg-muted); }
  .hero-status-meta  { color: var(--fg-mid); }

  /* Title — word-by-word slide-up on initial load */
  .hero-title {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 14px;
  }
  .hero-title-word, .hero-title-arrow {
    display: inline-block;
    opacity: 0;
    transform: translateY(18px);
    animation: hero-title-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero-title-word:nth-of-type(1) { animation-delay: 0.10s; }
  .hero-title-arrow              { animation-delay: 0.35s; color: var(--accent-text); }
  .hero-title-word-accent        { animation-delay: 0.55s; }
  @keyframes hero-title-in {
    to { opacity: 1; transform: translateY(0); }
  }
  @media (max-width: 640px) {
    .hero-title { gap: 0 10px; }
  }

  /* Stats strip — mono labels stacked under a thin top rule */
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1.5px dashed var(--border-mid);
    padding-top: 14px;
    max-width: 480px;
  }
  .hero-stat {
    flex: 1 1 auto;
    min-width: 90px;
    padding-right: 22px;
    border-right: 1.5px dashed var(--border);
    margin-right: 22px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .hero-stat:last-child {
    border-right: none;
    padding-right: 0;
    margin-right: 0;
  }
  .hero-stat-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    color: var(--accent-text);
    line-height: 1;
    letter-spacing: -0.01em;
    text-transform: lowercase;
  }
  .hero-stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  @media (max-width: 640px) {
    .hero-stats { padding-top: 12px; }
    .hero-stat  { min-width: 76px; padding-right: 14px; margin-right: 14px; }
    .hero-stat-value { font-size: 17px; }
  }

  /* Scroll cue — pinned to bottom of hero, subtle bounce, fades on scroll */
  .hero-scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 22px;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    z-index: 5;
    opacity: 0.85;
    transition: color 200ms ease, opacity 200ms ease;
  }
  .hero-scroll-cue:hover {
    color: var(--accent-text);
    opacity: 1;
  }
  .hero-scroll-cue-label { line-height: 1; }
  .hero-scroll-cue-arrow {
    width: 16px;
    height: 24px;
    display: inline-block;
    animation: hero-scroll-bounce 2.2s ease-in-out infinite;
  }
  .hero-scroll-cue-arrow svg { width: 100%; height: 100%; display: block; }
  /* The dot inside the mouse-glyph "scrolls" down inside the rectangle */
  .hero-scroll-cue-arrow line {
    animation: hero-scroll-dot 1.6s ease-in-out infinite;
  }
  @keyframes hero-scroll-bounce {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(6px); }
  }
  @keyframes hero-scroll-dot {
    0%       { transform: translateY(-2px); opacity: 0.4; }
    40%, 60% { transform: translateY(2px);  opacity: 1; }
    100%     { transform: translateY(6px);  opacity: 0;  }
  }
  @media (max-width: 900px) {
    .hero-scroll-cue { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-text-parallax { transform: none !important; opacity: 1 !important; }
    .now-dot, .hero-status-dot,
    .hero-scroll-cue-arrow, .hero-scroll-cue-arrow line,
    .hero-title-word, .hero-title-arrow { animation: none !important; }
    .hero-title-word, .hero-title-arrow { opacity: 1; transform: none; }
  }
</style>

<script>
  // Hero text parallax — text drifts up at 0.25× scroll speed, capped at 100px.
  (() => {
    type W = Window & { __heroParallaxBound?: boolean };
    const w = window as W;
    if (w.__heroParallaxBound) return;
    w.__heroParallaxBound = true;

    let ticking = false;
    const apply = () => {
      const el = document.querySelector<HTMLElement>('.hero-text-parallax');
      if (!el) return;
      const y = Math.min(window.scrollY * 0.25, 100);
      const opacity = Math.max(0, 1 - window.scrollY / 700);
      el.style.transform = `translate3d(0, ${-y}px, 0)`;
      el.style.opacity = String(opacity);
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(apply);
      }
    }, { passive: true });
    apply();
  })();
</script>
