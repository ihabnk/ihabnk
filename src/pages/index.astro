---
import Base from '../layouts/Base.astro';
import HeroVisual from '../components/HeroVisual.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog-en', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const STOAT_URL = 'https://stoat.chat/server/01KRX7GT1KEA2BK47257B1XGP1/channel/01KRX7GT1KB53TTBX7BTKZ4529';
---

<Base title="ihabnk" description="QA Engineer turned AI Product builder">

  <!-- ═══════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-[780px] flex items-center overflow-hidden" style="background:var(--bg-page)">

    <HeroVisual />

    <div class="relative z-10 w-full max-w-5xl mx-auto px-4 sm:px-6 py-20">
      <div class="max-w-[600px]">

        <span class="section-label mb-5 block tracking-[0.08em]">// software engineer</span>

        <h1 class="font-bold leading-[1.0] mb-5" style="font-size:clamp(40px,9vw,72px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em">
          QA Engineering → AI Product
        </h1>

        <p class="text-[17px] leading-[1.7] mb-6 max-w-[480px]" style="color:var(--fg-mid)">
          I build AI-augmented quality systems and ship digital products that actually work.
        </p>

        <!-- Code snippet card -->
        <div class="card-brutal mb-8 inline-block px-5 py-4" style="background:var(--bg-card)">
          <div class="font-mono text-[13px] line-through" style="color:var(--pop-red)"># before: manual QA → delayed releases</div>
          <div class="font-mono text-[13px] mt-1" style="color:var(--accent-text)"># after:  AI-augmented quality systems that ship</div>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href="/blog" class="btn-primary inline-flex items-center gap-2 font-bold text-sm px-6 h-11 rounded-[4px]">
            Read articles
          </a>
          <a href="/reviews" class="ghost-btn inline-flex items-center gap-2 text-sm px-6 h-11 rounded-[4px]">
            Reviews
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       RECENT ARTICLES
       ═══════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-20">
    <div class="glow-sep mb-14"></div>

    <div class="flex items-end justify-between mb-10">
      <div>
        <span class="section-label mb-2">// articles</span>
        <h2 class="font-bold" style="font-size:clamp(32px,4vw,44px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1">Recent Articles</h2>
      </div>
      <a href="/blog" class="font-mono text-[11px] transition-opacity duration-200 hover:opacity-70" style="color:var(--accent-text)">
        All articles →
      </a>
    </div>

    {posts.length === 0 ? (
      <p class="font-mono text-sm" style="color:var(--fg-muted)">No posts yet.</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, i) => <BlogCard {post} animate stagger={Math.min(i + 1, 4) as 1|2|3|4} />)}
      </div>
    )}
  </section>

  <!-- ═══════════════════════════════════════════
       COMMUNITY
       ═══════════════════════════════════════════ -->
  <section id="community" class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
    <div class="glow-sep mb-14"></div>

    <div
      class="card-brutal community-card relative overflow-hidden p-7 sm:p-10"
      style="background:var(--bg-card)"
    >
      <!-- Decorative accent glow in the top-right -->
      <div
        aria-hidden="true"
        class="absolute pointer-events-none"
        style="top:-60px;right:-60px;width:280px;height:280px;background:radial-gradient(circle at center, var(--accent-glow), transparent 65%)"
      ></div>

      <div class="relative flex flex-col gap-6 lg:flex-row lg:items-center lg:gap-10">

        <div class="flex-1">
          <span class="section-label mb-3 block">// community</span>
          <h2
            class="font-bold mb-4"
            style="font-size:clamp(26px,3.6vw,38px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1.08"
          >Build alongside other QA &amp; AI engineers</h2>
          <p
            class="text-[16px] leading-[1.65] max-w-[560px]"
            style="color:var(--fg-mid)"
          >
            I run a Stoat channel where I share works-in-progress, swap tooling
            notes, and answer questions from people moving from QA into AI
            product work. Pull up a chair — it's quiet, useful, and zero noise.
          </p>

          <!-- Trio of fine-print value props -->
          <ul class="mt-5 flex flex-wrap gap-x-5 gap-y-2 font-mono text-[11px]" style="color:var(--fg-muted)">
            <li><span style="color:var(--accent-text);font-weight:700">·</span> Tool deep-dives</li>
            <li><span style="color:var(--accent-text);font-weight:700">·</span> Code review threads</li>
            <li><span style="color:var(--accent-text);font-weight:700">·</span> Career questions, answered</li>
          </ul>
        </div>

        <div class="flex-shrink-0">
          <a
            href={STOAT_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary inline-flex items-center gap-2 font-bold text-sm px-6 h-12 rounded-[4px]"
          >
            Join the channel
            <span aria-hidden="true">↗</span>
          </a>
        </div>

      </div>
    </div>
  </section>

</Base>

<script>
  const io = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('fade-up'); io.unobserve(e.target); }
    }),
    { threshold: 0.06 }
  );
  document.querySelectorAll('[data-tags]').forEach(el => io.observe(el));
</script>
