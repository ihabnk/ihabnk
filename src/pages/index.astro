---
import Base from '../layouts/Base.astro';
import HeroVisual from '../components/HeroVisual.astro';
import BlogCard from '../components/BlogCard.astro';
import ReviewCard from '../components/ReviewCard.astro';
import ReviewArt from '../components/ReviewArt.astro';
import GuideCard from '../components/GuideCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog-en', ({ data }) => !data.draft);
const allReviews = await getCollection('reviews-en', ({ data }) => !data.draft);
const allGuides = await getCollection('guides-en', ({ data }) => !data.draft);

const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Guidebook spotlight — earliest guides across levels (beginner first) so the
// home page shows the path starts with the absolute fundamentals.
const levelRank = { beginner: 0, intermediate: 1, advanced: 2 } as const;
const guidebookSpotlight = [...allGuides]
  .sort((a, b) =>
    (levelRank[a.data.level] - levelRank[b.data.level]) || (a.data.order - b.data.order),
  )
  .slice(0, 3);

// Flagship comparison for the reviews pillar — newest featured comparison,
// falling back to the newest review of any kind.
const featuredReview =
  allReviews
    .filter((r) => r.data.kind === 'comparison' && r.data.featured)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0]
  ?? allReviews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0];

// The rest of the reviews, newest first, shown as a grid beneath the flagship.
const otherReviews = allReviews
  .filter((r) => r.id !== featuredReview?.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Choose your path — level-based entry points into the site.
const paths = [
  {
    tag: 'New to QA',
    quote: '“I want in, but I don’t know what to learn first.”',
    desc: 'Start with the fundamentals — what the job really is, and the skills that actually get you hired.',
    href: '/start',
    cta: 'Start the basics',
  },
  {
    tag: 'Growing in QA',
    quote: '“I know the basics — now make me good.”',
    desc: 'API testing, automation, CI/CD, and test strategy that holds up once it meets production.',
    href: '/guides#intermediate',
    cta: 'Level up',
  },
  {
    tag: 'Advanced quality',
    quote: '“Show me the hard, current stuff.”',
    desc: 'Evals, AI-assisted testing, and designing quality strategy for a whole organization.',
    href: '/guides#advanced',
    cta: 'Go deeper',
  },
];

const LINKEDIN_URL = 'https://linkedin.com/in/ihabnk';
const GITHUB_URL   = 'https://github.com/ihabnk';
const BLUESKY_URL  = 'https://bsky.app/profile/ihabnk.org';
const STOAT_URL    = 'https://stoat.chat/server/01KRX7GT1KEA2BK47257B1XGP1/channel/01KRX7GT1KB53TTBX7BTKZ4529';

const writesAbout = ['Testing tools', 'Evals', 'Test automation', 'AI quality', 'QA careers'];

const why = [
  {
    n: '01',
    title: 'A verdict, every time',
    sub: 'Every review and comparison commits to a recommendation — with the scores, the trade-offs, and where it would lose.',
  },
  {
    n: '02',
    title: 'Written from production',
    sub: 'Notes from a decade of shipping and breaking real systems. Not vendor decks, not borrowed takes.',
  },
  {
    n: '03',
    title: 'Signal over noise',
    sub: 'No hype cycles and no sponsored verdicts — just what holds up once real users arrive.',
  },
];
---

<Base
  title="Testerhood"
  description="Testerhood — the community where software testers learn, level up, and belong. A 30-day onboarding game, a hands-on tool lab, interactive lessons, and honest reviews."
>

  <!-- ═══════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-[520px] sm:min-h-[640px] lg:min-h-[700px] flex items-center overflow-hidden" style="background:var(--bg-page)">

    <HeroVisual />

    <div class="relative z-10 w-full max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
      <div class="max-w-[640px] hero-text-parallax" data-anim="hero-stagger">

        <!-- Category chip: pulsing live dot + who this is for -->
        <div class="hero-status mb-5">
          <span class="hero-status-dot" aria-hidden="true"></span>
          <span class="hero-status-label">A community for software testers — now recruiting</span>
        </div>

        <h1 class="font-bold leading-[1.02] mb-2 hero-title" data-anim="split-chars" style="font-size:clamp(34px,7.4vw,72px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.015em">
          <span class="hero-title-line">Testing is lonely.</span>
          <span class="hero-title-line">It doesn't have to be.</span>
          <span class="hero-title-line hero-title-accent">Welcome to the hood.</span>
        </h1>

        <svg class="hero-squiggle" data-anim="draw" viewBox="0 0 260 16" fill="none" aria-hidden="true">
          <path d="M4 10 Q 20 2, 36 9 T 68 9 T 100 9 T 132 9 T 164 9 T 196 9 T 228 9 T 256 8"
            stroke="var(--accent)" stroke-width="3.5" stroke-linecap="round" />
        </svg>

        <p class="text-[17px] sm:text-[18px] leading-[1.6] mb-8 max-w-[560px]" style="color:var(--fg-mid)">
          Testerhood is where testers grow together — a 30-day onboarding game,
          a hands-on tool lab, interactive lessons, honest tool reviews, and
          people who speak fluent bug report.
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="/start" class="btn-primary inline-flex items-center gap-2 font-bold text-sm px-6 h-11 rounded-[4px]">
            Join the hood
          </a>
          <a href="/reviews" class="ghost-btn inline-flex items-center gap-2 font-bold text-sm px-6 h-11 rounded-[4px]">
            Browse reviews
          </a>
        </div>

      </div>
    </div>

    <!-- Scroll cue -->
    <a class="hero-scroll-cue" href="#paths" aria-label="Choose your path">
      <span class="hero-scroll-cue-label">scroll</span>
      <span class="hero-scroll-cue-arrow" aria-hidden="true">
        <svg viewBox="0 0 16 24" xmlns="http://www.w3.org/2000/svg">
          <rect x="0.75" y="0.75" width="14.5" height="22.5" rx="7" style="fill:none;stroke:currentColor;stroke-width:1.5"/>
          <line x1="8" y1="6" x2="8" y2="11" style="stroke:currentColor;stroke-width:1.8;stroke-linecap:round"/>
        </svg>
      </span>
    </a>
  </section>

  <!-- ═══════════════════════════════════════════
       INSIDE THE HOOD — pinned horizontal tour
       ═══════════════════════════════════════════ -->
  <section class="hood-strip" data-anim="hscroll" aria-label="What's inside Testerhood">
    <div class="hood-head">
      <span class="section-label">// inside the hood</span>
      <h2 class="hood-h2">One neighborhood, six front doors.</h2>
      <span class="hood-hint" aria-hidden="true">scroll →</span>
    </div>
    <div class="hood-track" data-hscroll-track>
      {[
        { n: '01', href: '/learn/qa-onboarding', title: 'The Game', desc: 'Play your first 30 days as a QA engineer — mentor included.', glyph: 'bit' },
        { n: '02', href: '/learn/qa-lab', title: 'The QA Lab', desc: 'Six real tools, simulated: API console, SQL, network tab, logs, locators, terminal.', glyph: 'flask' },
        { n: '03', href: '/start', title: 'Lessons', desc: 'Interactive, Brilliant-style lessons — tap, answer, learn by doing.', glyph: 'play' },
        { n: '04', href: '/guides', title: 'The Guidebook', desc: 'Structured written guides from first test plan to org-wide strategy.', glyph: 'book' },
        { n: '05', href: '/reviews', title: 'Reviews', desc: 'Independent tool reviews and head-to-heads. No marketing, no affiliate spin.', glyph: 'scale' },
        { n: '06', href: '/start#community', title: 'The Community', desc: 'People who speak fluent bug report. Quiet, practical, zero gatekeeping.', glyph: 'chat' },
      ].map((c) => (
        <a class="hood-panel card-brutal" href={c.href} data-hscroll-panel>
          <span class="hood-n" aria-hidden="true">{c.n}</span>
          <span class="hood-glyph" aria-hidden="true">
            {c.glyph === 'bit' && (
              <svg viewBox="0 0 48 48" fill="none"><rect x="8" y="8" width="32" height="32" rx="8" stroke="currentColor" stroke-width="2.5"/><circle cx="22" cy="22" r="5" stroke="currentColor" stroke-width="2.5"/><path d="M18 33 q6 4 12 0" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
            )}
            {c.glyph === 'flask' && (
              <svg viewBox="0 0 48 48" fill="none"><path d="M19 6 h10 M21 6 v12 L10 38 a4 4 0 0 0 3.6 6 h20.8 a4 4 0 0 0 3.6 -6 L27 18 V6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 30 h18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
            )}
            {c.glyph === 'play' && (
              <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="17" stroke="currentColor" stroke-width="2.5"/><path d="M20 17 L31 24 L20 31 Z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/></svg>
            )}
            {c.glyph === 'book' && (
              <svg viewBox="0 0 48 48" fill="none"><path d="M24 12 C20 8 13 8 9 10 v28 c4 -2 11 -2 15 2 c4 -4 11 -4 15 -2 V10 c-4 -2 -11 -2 -15 2 v30" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            )}
            {c.glyph === 'scale' && (
              <svg viewBox="0 0 48 48" fill="none"><path d="M24 8 v30 M12 14 l24 -4 M10 38 h28" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M12 14 l-5 12 a6 5 0 0 0 10 0 z M36 10 l-5 12 a6 5 0 0 0 10 0 z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/></svg>
            )}
            {c.glyph === 'chat' && (
              <svg viewBox="0 0 48 48" fill="none"><path d="M8 12 a4 4 0 0 1 4 -4 h18 a4 4 0 0 1 4 4 v10 a4 4 0 0 1 -4 4 H18 l-7 6 v-6 h-1 a4 4 0 0 1 -4 -4 z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/><path d="M38 20 h1 a4 4 0 0 1 4 4 v8 a4 4 0 0 1 -4 4 h-1 v5 l-6 -5 h-8" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/></svg>
            )}
          </span>
          <span class="hood-title">{c.title}</span>
          <span class="hood-desc">{c.desc}</span>
          <span class="hood-cta" aria-hidden="true">Enter →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CHOOSE YOUR PATH — level-based entry points
       ═══════════════════════════════════════════ -->
  <section id="paths" class="max-w-5xl mx-auto px-4 sm:px-6 pt-12 sm:pt-16 scroll-mt-24">
    <div class="mb-6 sm:mb-8" data-anim="section-head">
      <span class="section-label mb-2 reveal-soft block">// choose your path</span>
      <h2 class="font-bold reveal-soft reveal-pop" style="font-size:clamp(30px,4vw,44px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1.02">
        Wherever you are with QA, there's a way in.
      </h2>
      <p class="mt-3 text-[15px] reveal-soft" style="color:var(--fg-mid);max-width:540px">
        This site serves three stages of a quality-engineering career. Pick the one that sounds like you.
      </p>
    </div>

    <div class="path-grid" data-anim="card-grid">
      {paths.map((p) => (
        <a href={p.href} class="path-card card-brutal group reveal" style="background:var(--bg-card)">
          <span class="path-card-tag">{p.tag}</span>
          <p class="path-card-quote">{p.quote}</p>
          <p class="path-card-desc">{p.desc}</p>
          <span class="path-card-cta">
            {p.cta}
            <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       THE GUIDEBOOK — spotlight on the learning path
       ═══════════════════════════════════════════ -->
  {guidebookSpotlight.length > 0 && (
    <section id="guidebook" class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16 scroll-mt-24">
      <div class="glow-sep mb-8 sm:mb-10"></div>

      <div class="flex items-end justify-between gap-4 mb-6 sm:mb-8">
        <div data-anim="section-head">
          <span class="section-label mb-2 reveal-soft block">// the guidebook</span>
          <h2 class="font-bold reveal-soft reveal-pop" style="font-size:clamp(30px,4vw,44px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1.02">
            A real path, not a reading list.
          </h2>
          <p class="mt-3 text-[15px] reveal-soft" style="color:var(--fg-mid);max-width:540px">
            Ordered, opinionated guides built from production experience — so you always know what to learn next.
          </p>
        </div>
        <a href="/guides" class="font-mono text-[11px] whitespace-nowrap transition-opacity duration-200 hover:opacity-70 shrink-0 pb-1" style="color:var(--accent-text)">
          Open the Guidebook →
        </a>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-anim="card-grid">
        {guidebookSpotlight.map((g, i) => (
          <GuideCard guide={g} animate stagger={Math.min(i + 1, 4) as 1|2|3|4} />
        ))}
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════
       REVIEWS & COMPARISONS — the pillar
       ═══════════════════════════════════════════ -->
  <section id="reviews" class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="glow-sep mb-8 sm:mb-10"></div>

    <div class="flex items-end justify-between gap-4 mb-6 sm:mb-8">
      <div data-anim="section-head">
        <span class="section-label mb-2 reveal-soft block">// reviews &amp; comparisons</span>
        <h2 class="font-bold reveal-soft reveal-pop" style="font-size:clamp(30px,4vw,44px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1.02">
          Tool reviews that pick a side.
        </h2>
        <p class="mt-3 text-[15px] reveal-soft" style="color:var(--fg-mid);max-width:520px">
          Honest, independent comparisons of the tools QA and engineering teams actually ship with — scored, opinionated, and updated as the tools change.
        </p>
      </div>
      <a href="/reviews" class="font-mono text-[11px] whitespace-nowrap transition-opacity duration-200 hover:opacity-70 shrink-0 pb-1" style="color:var(--accent-text)">
        All reviews →
      </a>
    </div>

    {featuredReview && (
      <a
        href={`/reviews/${featuredReview.id}`}
        class="featured-review-card card-brutal group block relative overflow-hidden reveal mb-5 sm:mb-6"
        style="background:var(--bg-card)"
        data-anim="featured"
      >
        <div class="featured-review-grid">
          <div class="featured-review-art">
            <ReviewArt slug={featuredReview.id} variant="hero" kind={featuredReview.data.kind} tools={featuredReview.data.tools ?? []} />
          </div>

          <div class="featured-review-body">
            <div class="flex items-center gap-2 flex-wrap mb-3">
              <span
                class="font-mono text-[10px] px-[10px] py-[3px] rounded-[3px] font-bold"
                style="background:var(--accent);color:var(--on-accent);letter-spacing:0.05em"
              >FLAGSHIP</span>
              {(featuredReview.data.tools ?? []).map((t, i) => (
                <>
                  {i > 0 && <span class="font-mono text-[10px]" style="color:var(--fg-muted)">vs</span>}
                  <span
                    class="font-mono text-[10px] px-[8px] py-[2px] rounded-[3px]"
                    style="border:1.5px solid var(--border-mid);color:var(--fg);background:var(--bg-page);letter-spacing:0.04em"
                  >{t}</span>
                </>
              ))}
            </div>

            <h3 class="font-bold leading-[1.18] mb-3" style="font-size:clamp(22px,3.4vw,32px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em">
              {featuredReview.data.title}
            </h3>

            {featuredReview.data.verdict && (
              <p class="text-[15px] leading-[1.65] mb-4 line-clamp-3" style="color:var(--fg-mid)">
                {featuredReview.data.verdict}
              </p>
            )}

            <span class="font-mono text-[11px] font-bold inline-flex items-center gap-2" style="color:var(--accent-text)">
              Read the comparison
              <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
            </span>
          </div>
        </div>
      </a>
    )}

    {otherReviews.length > 0 && (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-anim="card-grid">
        {otherReviews.map((review, i) => (
          <ReviewCard {review} animate stagger={Math.min(i + 1, 4) as 1|2|3|4} />
        ))}
      </div>
    )}
  </section>

  <!-- ═══════════════════════════════════════════
       THE STANDARD — why a review here is trustworthy
       ═══════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-12 sm:pb-16" aria-label="What makes this site different">
    <div class="glow-sep mb-8 sm:mb-10"></div>

    <div class="mb-6 sm:mb-8" data-anim="section-head">
      <span class="section-label mb-2 reveal-soft block">// the standard</span>
      <h2 class="font-bold reveal-soft reveal-pop" style="font-size:clamp(28px,3.6vw,40px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1.04">
        What makes a review here worth trusting.
      </h2>
    </div>

    <div class="why-strip" data-anim="card-grid">
      {why.map((w, i) => (
        <div class={`why-card reveal stagger-${i + 1}`}>
          <div class="why-index">{w.n}</div>
          <div class="why-title">{w.title}</div>
          <p class="why-sub">{w.sub}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       COMMUNITY
       ═══════════════════════════════════════════ -->
  <section id="community" class="max-w-5xl mx-auto px-4 sm:px-6 pb-12 sm:pb-16">
    <div class="glow-sep mb-8 sm:mb-10"></div>

    <div
      class="card-brutal community-card relative overflow-hidden p-6 sm:p-8"
      style="background:var(--bg-card)"
    >
      <div
        aria-hidden="true"
        class="absolute pointer-events-none"
        style="top:-60px;right:-60px;width:280px;height:280px;background:radial-gradient(circle at center, var(--accent-glow), transparent 65%)"
      ></div>

      <div class="relative flex flex-col gap-5 lg:flex-row lg:items-center lg:gap-8">

        <div class="flex-1" data-anim="section-head">
          <span class="section-label mb-3 block reveal-soft">// community</span>
          <h2
            class="font-bold mb-3 reveal-soft reveal-pop"
            style="font-size:clamp(26px,3.6vw,38px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1.08"
          >A quiet room for serious quality work.</h2>
          <p
            class="text-[16px] leading-[1.6] max-w-[560px] reveal-soft"
            style="color:var(--fg-mid)"
          >
            A small Stoat channel for QA and AI engineers who like their
            discussion practical and low-volume — tooling deep-dives, eval
            strategy, and honest answers about doing quality work in the AI
            era. No noise, no growth-hacking. Just useful.
          </p>

          <ul class="mt-4 flex flex-wrap gap-x-5 gap-y-2 font-mono text-[11px]" style="color:var(--fg-muted)">
            <li><span style="color:var(--accent-text);font-weight:700">·</span> Tooling deep-dives</li>
            <li><span style="color:var(--accent-text);font-weight:700">·</span> Eval &amp; testing strategy</li>
            <li><span style="color:var(--accent-text);font-weight:700">·</span> Career questions, answered straight</li>
          </ul>
        </div>

        <div class="flex-shrink-0">
          <a
            href={STOAT_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary inline-flex items-center gap-2 font-bold text-sm px-6 h-12 rounded-[4px]"
          >
            Join the channel
            <span aria-hidden="true">↗</span>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FOLLOW THE WORK — LinkedIn-first conversion band
       ═══════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-12 sm:pb-16" aria-label="Follow the work">
    <div class="glow-sep mb-8 sm:mb-10"></div>

    <div class="follow-card card-brutal p-6 sm:p-8" style="background:var(--bg-card)" data-anim="featured">
      <div class="follow-grid">
        <div>
          <span class="section-label mb-3 block">// follow the work</span>
          <h2
            class="font-bold mb-3"
            style="font-size:clamp(24px,3.2vw,34px);color:var(--fg);font-family:var(--font-display);letter-spacing:-0.01em;line-height:1.1"
          >Most of these ideas start on LinkedIn.</h2>
          <p class="text-[15px] leading-[1.6] mb-5" style="color:var(--fg-mid);max-width:520px">
            I post short, practical takes on testing tools, evals, and quality a
            few times a week. The ones worth keeping grow into the reviews and
            essays here — so following is the easiest way to get the thinking as
            it forms.
          </p>

          <ul class="follow-topics" aria-label="What I write about">
            {writesAbout.map((t) => <li>{t}</li>)}
          </ul>
        </div>

        <div class="follow-actions">
          <a
            href={LINKEDIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary inline-flex items-center justify-center gap-2 font-bold text-sm px-6 h-12 rounded-[4px] w-full"
          >
            Follow on LinkedIn
            <span aria-hidden="true">↗</span>
          </a>
          <div class="follow-secondary">
            <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="ghost-btn inline-flex items-center justify-center font-bold text-[13px] px-4 h-10 rounded-[4px]">GitHub ↗</a>
            <a href={BLUESKY_URL} target="_blank" rel="noopener noreferrer" class="ghost-btn inline-flex items-center justify-center font-bold text-[13px] px-4 h-10 rounded-[4px]">Bluesky ↗</a>
            <a href="/rss.xml" class="ghost-btn inline-flex items-center justify-center font-bold text-[13px] px-4 h-10 rounded-[4px]">RSS →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LATEST WRITING
       ═══════════════════════════════════════════ -->
  <section id="articles" class="max-w-5xl mx-auto px-4 sm:px-6 pb-16 scroll-mt-24">
    <div class="glow-sep mb-8 sm:mb-10"></div>

    <div class="flex items-end justify-between mb-6 sm:mb-8">
      <div data-anim="section-head">
        <span class="section-label mb-2 reveal-soft block">// writing</span>
