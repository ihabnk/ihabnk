---
import Base from '../../layouts/Base.astro';
import HeroVisual from '../../components/HeroVisual.astro';
import BlogCard from '../../components/BlogCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/ui';
import { fetchRepos } from '../../lib/github';

const lang = 'en' as const;
const t = useTranslations(lang);

const posts = (await getCollection('blog-en', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const repos = await fetchRepos('ihabnk');
---

<Base title="ihabnk" description="QA Engineer transitioning to AI Product building" lang={lang}>

  <!-- Hero -->
  <section class="relative min-h-[680px] flex items-center overflow-hidden" style="background:var(--bg-page)">

    <HeroVisual />

    <div class="relative z-10 w-full max-w-5xl mx-auto px-4 sm:px-6 py-20">
      <div class="max-w-[520px]">

        <span class="section-label mb-5 block tracking-[0.08em]">whoami</span>

        <h1 class="font-display font-bold leading-[0.95] mb-5 uppercase tracking-tight" style="font-size:clamp(3.5rem,9vw,6rem);color:var(--fg);font-family:var(--font-display)">
          From Quality<br />to the<br />Future of AI
        </h1>

        <p class="text-base leading-[1.75] mb-8 max-w-[420px]" style="color:var(--fg-mid)">
          QA engineer turned AI product builder.<br />
          I write about quality, automation, and the tools changing the game.
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href="/en/blog"
            class="inline-flex items-center gap-2 font-bold text-sm px-6 h-12 rounded-[10px] transition-opacity duration-200 hover:opacity-[0.88]"
            style="background:var(--accent);color:var(--on-accent);box-shadow:0 2px 14px var(--accent-glow)"
          >
            {t('hero.cta.articles')}
          </a>
          <a
            href="#projects"
            class="inline-flex items-center gap-2 text-sm px-6 h-12 rounded-[10px] transition-colors duration-200"
            style="background:transparent;border:1px solid var(--border-mid);color:var(--fg-mid)"
          >
            {t('hero.cta.projects')}
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Recent Articles -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-20">
    <div class="glow-sep mb-14"></div>

    <div class="flex items-end justify-between mb-10">
      <div>
        <span class="section-label mb-2">// articles</span>
        <h2 class="text-[30px] font-bold" style="color:var(--fg)">{t('blog.recent')}</h2>
      </div>
      <a href="/en/blog" class="font-mono text-[11px] transition-opacity duration-200 hover:opacity-70" style="color:var(--accent-text)">
        {t('blog.all')} →
      </a>
    </div>

    {posts.length === 0 ? (
      <p class="font-mono text-sm" style="color:var(--fg-muted)">{t('blog.noPosts')}</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, i) => <BlogCard {post} {lang} animate stagger={Math.min(i + 1, 4) as 1|2|3|4} />)}
      </div>
    )}
  </section>

  <!-- Projects -->
  <section id="projects" class="max-w-5xl mx-auto px-4 sm:px-6 py-20">
    <div class="glow-sep mb-14"></div>

    <div class="flex items-end justify-between mb-10">
      <div>
        <span class="section-label mb-2">// projects</span>
        <h2 class="text-[30px] font-bold" style="color:var(--fg)">{t('projects.heading')}</h2>
      </div>
      <a
        href="https://github.com/ihabnk"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-[11px] transition-opacity duration-200 hover:opacity-70"
        style="color:var(--accent-text)"
      >GitHub →</a>
    </div>

    {repos.length === 0 ? (
      <p class="font-mono text-sm" style="color:var(--fg-muted)">// no repos loaded — visit GitHub directly</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {repos.map(repo => <ProjectCard {repo} />)}
      </div>
    )}
  </section>

  <!-- Support CTA -->
  <section
    id="support"
    class="py-20 flex flex-col items-center gap-4 text-center"
    style="background:var(--bg-surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border)"
  >
    <h3 class="text-[26px] font-bold" style="color:var(--fg)">☕ Enjoying the content?</h3>
    <p class="text-[15px] leading-relaxed max-w-sm" style="color:var(--fg-mid)">
      {t('support.body')}
    </p>
    <a
      href="https://www.buymeacoffee.com/ihabnk"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 font-bold text-sm px-8 h-12 rounded-[10px] mt-2 transition-opacity duration-200 hover:opacity-[0.88]"
      style="background:var(--accent);color:var(--on-accent);box-shadow:0 2px 16px var(--accent-glow)"
    >
      ☕ {t('support.bmc')}
    </a>
  </section>

</Base>

<script>
  const io = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('fade-up'); io.unobserve(e.target); } }),
    { threshold: 0.06 }
  );
  document.querySelectorAll('[data-tags]').forEach(el => io.observe(el));
</script>
