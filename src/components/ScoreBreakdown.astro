---
interface Props {
  scores?: Record<string, number>;
  scoresByTool?: Record<string, Record<string, number>>;
  tools?: string[];
  max?: number;
  methodology?: string;
}

const {
  scores,
  scoresByTool,
  tools = [],
  max = 5,
  methodology = 'Scores reflect practical evaluation across setup, reliability, debugging, speed, ecosystem, CI/CD, documentation, and language support.',
} = Astro.props;

const toolList = scoresByTool
  ? (tools.length ? tools.filter(t => scoresByTool[t]) : Object.keys(scoresByTool))
  : [];

const criteria = scoresByTool
  ? Array.from(new Set(toolList.flatMap(t => Object.keys(scoresByTool[t] ?? {}))))
  : Object.keys(scores ?? {});

const toolAvgs = scoresByTool
  ? toolList.map(t => {
      const vals = Object.values(scoresByTool[t] ?? {});
      const avg = vals.length ? vals.reduce((s, v) => s + v, 0) / vals.length : 0;
      return { tool: t, avg };
    })
  : [];

const entries = scores ? Object.entries(scores) : [];
const singleAvg = entries.length
  ? entries.reduce((s, [, v]) => s + v, 0) / entries.length
  : 0;

const isComparison = !!scoresByTool && toolList.length > 0;

// CSS custom property for grid template column count (criterion + N tools)
const gridCols = `minmax(0,1.4fr) repeat(${toolList.length}, minmax(0,1fr))`;
---

<section
  class="card-brutal mb-10 p-5 sm:p-6"
  style="background:var(--bg-card)"
  aria-label="Scoring breakdown"
>
  <div class="flex items-baseline justify-between gap-3 mb-2 flex-wrap">
    <span class="section-label">// scoring</span>
    {isComparison ? (
      <div class="flex gap-3 flex-wrap font-mono text-[12px]" style="color:var(--fg-muted)">
        {toolAvgs.map(({ tool, avg }) => (
          <span>{tool} <strong style="color:var(--accent-text)">{avg.toFixed(1)}</strong> / {max}</span>
        ))}
      </div>
    ) : entries.length > 0 && (
      <span class="font-mono text-[12px]" style="color:var(--fg-muted)">
        Avg <strong style="color:var(--accent-text)">{singleAvg.toFixed(1)}</strong> / {max}
      </span>
    )}
  </div>

  <p class="text-[12px] mb-5 leading-snug" style="color:var(--fg-muted);font-family:var(--font-mono)">
    {methodology}
  </p>

  {isComparison ? (
    <ul class="score-grid flex flex-col gap-3" style={`--cols:${toolList.length}`}>
      <li class="score-row score-row--head" style={`grid-template-columns:${gridCols}`}>
        <span class="font-mono text-[11px] score-head-label" style="color:var(--fg-muted);letter-spacing:0.04em">Criterion</span>
        {toolList.map(t => (
          <span class="font-mono text-[11px] font-bold score-head-tool" style="color:var(--fg);letter-spacing:0.04em">{t}</span>
        ))}
      </li>

      {criteria.map(label => (
        <li class="score-row" style={`grid-template-columns:${gridCols}`}>
          <span class="score-criterion text-[14px]" style="color:var(--fg);font-family:var(--font-sans)">{label}</span>
          {toolList.map(t => {
            const v = scoresByTool![t]?.[label];
            if (v === undefined) {
              return (
                <span class="score-cell font-mono text-[12px]" style="color:var(--fg-muted)" data-tool={t}>—</span>
              );
            }
            return (
              <span class="score-cell flex items-center gap-2" aria-label={`${t} ${label} ${v} of ${max}`} data-tool={t}>
                <span class="flex gap-[3px]" aria-hidden="true" style="flex:1">
                  {Array.from({ length: max }).map((_, i) => (
                    <span
                      class="block"
                      style={`flex:1;height:7px;border:1.5px solid var(--fg);background:${i < v ? 'var(--accent)' : 'var(--bg-page)'}`}
                    ></span>
                  ))}
                </span>
                <span
                  class="font-mono text-[11px] font-bold tabular-nums"
                  style="color:var(--accent-text);min-width:18px;text-align:right"
                >{v}</span>
              </span>
            );
          })}
        </li>
      ))}
    </ul>
  ) : (
    <ul class="flex flex-col gap-3">
      {entries.map(([label, value]) => (
        <li class="grid items-center gap-3" style="grid-template-columns:minmax(0,1fr) 64px auto">

          <span class="text-[14px]" style="color:var(--fg);font-family:var(--font-sans)">{label}</span>

          <span class="flex gap-1" aria-hidden="true">
            {Array.from({ length: max }).map((_, i) => (
              <span
                class="block"
                style={`flex:1;height:8px;border:1.5px solid var(--fg);background:${i < value ? 'var(--accent)' : 'var(--bg-page)'}`}
              ></span>
            ))}
          </span>

          <span
            class="font-mono text-[12px] font-bold tabular-nums"
            style="color:var(--accent-text);min-width:40px;text-align:right"
            aria-label={`${value} of ${max}`}
          >{value.toFixed(1)}/{max}</span>

        </li>
      ))}
    </ul>
  )}
</section>

<style>
  .score-row {
    display: grid;
    align-items: center;
    gap: 0.75rem;
  }
  .score-row--head {
    padding-bottom: 0.5rem;
    border-bottom: 1.5px solid var(--fg);
  }

  /* Mobile: stack criterion + per-tool cells vertically; prefix each cell with tool name */
  @media (max-width: 560px) {
    .score-row {
      grid-template-columns: 1fr !important;
      gap: 0.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 1.5px dashed var(--border);
    }
    .score-row:last-child { border-bottom: 0; padding-bottom: 0; }

    .score-row--head { display: none; }

    .score-criterion {
      font-weight: 700;
      font-size: 13px;
    }
    .score-cell {
      display: grid;
      grid-template-columns: 80px 1fr auto;
      gap: 0.5rem;
      align-items: center;
    }
    .score-cell::before {
      content: attr(data-tool);
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--fg-muted);
      letter-spacing: 0.04em;
    }
  }
</style>
