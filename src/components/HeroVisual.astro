---
// The Testerhood recruitment poster: Bit does Uncle Sam. "BIT WANTS YOU."
// Pure CSS animation (float, stamp slam, pointing pulse) — no JS.
---

<div class="hv-root" aria-hidden="true">

  <!-- Soft ambient glow behind the poster -->
  <div class="hv-aura"></div>

  <!-- Grid backdrop for technical feel -->
  <div class="hv-grid"></div>

  <!-- Left-side fade for hero text readability -->
  <div class="hv-fade"></div>

  <!-- The poster -->
  <div class="hv-poster">
    <div class="hv-poster-top">★ CITIZENS OF SOFTWARE ★</div>

    <!-- Bit in the star-banded top hat, pointing at YOU -->
    <svg class="hv-bit" viewBox="0 0 160 178" fill="none">
      <!-- hard shadow -->
      <rect x="33" y="49" width="98" height="98" rx="21" fill="var(--fg)" opacity="0.9" />
      <!-- body -->
      <rect x="28" y="44" width="98" height="98" rx="21" fill="var(--accent)" stroke="var(--fg)" stroke-width="3.5" />

      <!-- top hat -->
      <rect x="46" y="4" width="62" height="34" rx="4" fill="#20303e" stroke="var(--fg)" stroke-width="3.5" />
      <rect x="46" y="24" width="62" height="12" fill="#b3402e" stroke="var(--fg)" stroke-width="3" />
      <path d="M60 30 l2.6 -5 2.6 5 -5.2 0z M74 30 l2.6 -5 2.6 5 -5.2 0z M88 30 l2.6 -5 2.6 5 -5.2 0z" fill="#f3e9d2" />
      <rect x="34" y="36" width="86" height="9" rx="4.5" fill="#20303e" stroke="var(--fg)" stroke-width="3.5" />

      <!-- stern recruiting eye (pupil group follows the cursor) -->
      <circle cx="77" cy="84" r="17" fill="#fff" stroke="var(--fg)" stroke-width="3" />
      <g class="hv-pupil">
        <circle cx="77" cy="86" r="7.5" fill="var(--fg)" />
        <circle cx="80" cy="82" r="2.4" fill="#fff" />
      </g>
      <path d="M58 66 L96 62" stroke="var(--fg)" stroke-width="4" stroke-linecap="round" />

      <!-- firm, patriotic mouth (morphs to a grin on hover — MorphSVG) -->
      <path class="hv-mouth" d="M68 116 L92 116" stroke="var(--fg)" stroke-width="4" stroke-linecap="round" fill="none" />

      <!-- the pointing arm: sleeve + big foreshortened hand, aimed at YOU -->
      <g class="hv-point">
        <path d="M46 132 Q56 152 74 158" stroke="var(--fg)" stroke-width="13" stroke-linecap="round" />
        <path d="M46 132 Q56 152 74 158" stroke="var(--accent)" stroke-width="7" stroke-linecap="round" />
        <circle cx="86" cy="158" r="15" fill="#f3e9d2" stroke="var(--fg)" stroke-width="3.5" />
        <rect x="94" y="150" width="26" height="13" rx="6.5" fill="#f3e9d2" stroke="var(--fg)" stroke-width="3.5" />
      </g>
    </svg>

    <div class="hv-line1">BIT</div>
    <div class="hv-line2">WANTS <span class="hv-you">YOU</span></div>
    <div class="hv-line3">for the <b>TESTERHOOD</b></div>

    <div class="hv-fineprint">
      no experience required · curiosity mandatory · bugs provided
    </div>

    <!-- the stamp slams in -->
    <div class="hv-stamp">NOW<br />RECRUITING</div>
  </div>

  <!-- Tiny floating enlistment card (depth + wink) -->
  <div class="hv-spec">
    <div class="hv-spec-row">
      <span class="hv-spec-k">recruits</span><span class="hv-spec-v">you, ideally</span>
    </div>
    <div class="hv-spec-row">
      <span class="hv-spec-k">requirement</span><span class="hv-spec-v">curiosity</span>
    </div>
    <div class="hv-spec-row">
      <span class="hv-spec-k">salary</span><span class="hv-spec-v">bugs. so many.</span>
    </div>
  </div>

</div>

<style>
.hv-root {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

/* ── Ambient amber glow ── */
.hv-aura {
  position: absolute;
  width: 620px; height: 620px;
  right: -120px; top: -120px;
  border-radius: 50%;
  background: radial-gradient(circle at center, var(--accent-glow) 0%, transparent 65%);
  filter: blur(2px);
  animation: hv-aura-drift 18s ease-in-out infinite;
}
@keyframes hv-aura-drift {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50%      { transform: translate(-30px, 20px) scale(1.08); }
}

/* ── Subtle grid ── */
.hv-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(to right, color-mix(in srgb, var(--fg) 6%, transparent) 1px, transparent 1px),
    linear-gradient(to bottom, color-mix(in srgb, var(--fg) 6%, transparent) 1px, transparent 1px);
  background-size: 40px 40px;
  mask-image: radial-gradient(ellipse at right center, black 30%, transparent 75%);
  -webkit-mask-image: radial-gradient(ellipse at right center, black 30%, transparent 75%);
  opacity: 0.5;
}

/* ── Left fade for text readability ── */
.hv-fade {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    var(--bg-page) 0%,
    var(--bg-page) 32%,
    color-mix(in srgb, var(--bg-page) 55%, transparent) 55%,
    transparent 100%
  );
}

/* ── The poster ── */
.hv-poster {
  pointer-events: auto; /* hover interactions: grin morph, stamp re-slam */
  position: absolute;
  right: 5%;
  top: 50%;
  transform: translateY(-50%) rotate(1.5deg);
  width: min(330px, 34vw);
  background: #f3e9d2;
  border: 3px solid var(--fg);
  border-radius: 6px;
  box-shadow: 8px 8px 0 var(--fg);
  padding: 16px 18px 18px;
  text-align: center;
  font-family: var(--font-display);
  color: #201b12;
  animation: hv-poster-float 9s ease-in-out infinite;
}
@keyframes hv-poster-float {
  0%, 100% { transform: translateY(-50%) rotate(1.5deg); }
  50%      { transform: translateY(calc(-50% - 8px)) rotate(1.2deg); }
}

.hv-poster-top {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.22em;
  color: #b3402e;
  border-top: 2px solid #201b12;
  border-bottom: 2px solid #201b12;
  padding: 5px 0;
  margin-bottom: 10px;
}

.hv-bit {
  width: 132px;
  height: auto;
  display: block;
  margin: 0 auto 4px;
}
/* the point: a slow, insistent jab toward the reader */
.hv-point {
  transform-origin: 52px 136px;
  animation: hv-jab 2.6s ease-in-out infinite;
}
@keyframes hv-jab {
  0%, 100% { transform: scale(1); }
  12%      { transform: scale(1.09); }
  24%      { transform: scale(1); }
}

.hv-line1 {
  font-size: 40px;
  font-weight: 800;
  line-height: 0.95;
  letter-spacing: 0.01em;
}
.hv-line2 {
  font-size: 30px;
  font-weight: 800;
  line-height: 1.05;
}
.hv-you {
  color: #b3402e;
  font-size: 36px;
  text-decoration: underline;
  text-decoration-thickness: 3px;
  text-underline-offset: 4px;
}
.hv-line3 {
  font-family: var(--font-sans);
  font-size: 14px;
  font-weight: 600;
  margin-top: 4px;
}
.hv-line3 b { font-family: var(--font-display); font-weight: 800; letter-spacing: 0.04em; }

.hv-fineprint {
  font-family: var(--font-mono);
  font-size: 8.5px;
  letter-spacing: 0.04em;
  color: #6e6250;
  border-top: 1.5px dashed #b9a887;
  margin-top: 10px;
  padding-top: 7px;
}

/* ── The stamp: slams in after the poster settles ── */
.hv-stamp {
  pointer-events: auto;
  position: absolute;
  top: 6px;
  right: -18px;
  transform: rotate(12deg) scale(3);
  opacity: 0;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 15px;
  line-height: 1.05;
  letter-spacing: 0.06em;
  color: #b3402e;
  border: 3px solid #b3402e;
  border-radius: 6px;
  padding: 5px 9px;
  background: color-mix(in srgb, #f3e9d2 82%, transparent);
  mix-blend-mode: multiply;
  animation: hv-stamp-slam 0.45s cubic-bezier(0.34, 1.3, 0.64, 1) 1.1s forwards;
}
@keyframes hv-stamp-slam {
  0%   { opacity: 0; transform: rotate(4deg) scale(3); }
  60%  { opacity: 1; transform: rotate(13deg) scale(0.94); }
  100% { opacity: 0.92; transform: rotate(12deg) scale(1); }
}

/* ── Floating enlistment card ── */
.hv-spec {
  position: absolute;
  right: calc(5% + min(330px, 34vw) - 60px);
  top: calc(50% + 150px);
  transform: rotate(-3deg);
  background: var(--bg-page);
  border: 2px solid var(--fg);
  border-radius: 6px;
  box-shadow: 4px 4px 0 var(--fg);
  padding: 10px 14px;
  font-family: var(--font-mono);
  min-width: 170px;
  animation: hv-spec-float 8s ease-in-out infinite;
  animation-delay: -3s;
}
@keyframes hv-spec-float {
  0%, 100% { transform: rotate(-3deg) translateY(0); }
  50%      { transform: rotate(-3deg) translateY(-10px); }
}
.hv-spec-row {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  font-size: 10px;
  line-height: 1.8;
}
.hv-spec-k { color: var(--fg-muted); }
.hv-spec-v { color: var(--accent-text); font-weight: 600; }

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce) {
  .hv-aura, .hv-poster, .hv-spec, .hv-point, .hv-stamp { animation: none; }
  .hv-stamp { opacity: 0.92; transform: rotate(12deg) scale(1); }
}

/* ── Small screens ── */
@media (max-width: 1024px) {
  .hv-spec { display: none; }
  .hv-poster { right: -4%; width: min(290px, 40vw); }
}
@media (max-width: 899px) {
  .hv-poster { display: none; }
  .hv-aura { width: 360px; height: 360px; right: -100px; top: 0; }
  .hv-grid { display: none; }
  .hv-fade {
    background: linear-gradient(
      to right,
      var(--bg-page) 0%,
      color-mix(in srgb, var(--bg-page) 80%, transparent) 60%,
      color-mix(in srgb, var(--bg-page) 55%, transparent) 100%
    );
  }
}
</style>

<script>
  /**
   * Interactive Bit: on fine pointers the poster tilts toward the cursor,
   * the pupil tracks it, and the pointing arm aims at it. GSAP takes over
   * transforms from the CSS keyframes (they'd fight otherwise).
   */
  import { gsap } from 'gsap';
  import { MorphSVGPlugin } from 'gsap/MorphSVGPlugin';

  gsap.registerPlugin(MorphSVGPlugin);

  declare global {
    interface Window { __hvCleanup?: () => void }
  }

  const MOUTH_STERN = 'M68 116 L92 116';
  const MOUTH_GRIN = 'M66 112 Q79 126 92 112';

  function setupPoster() {
    window.__hvCleanup?.();
    const poster = document.querySelector<HTMLElement>('.hv-poster');
    if (!poster) return;
    if (!matchMedia('(pointer: fine)').matches) return;
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (matchMedia('(max-width: 899px)').matches) return;

    const pupil = poster.querySelector<SVGGElement>('.hv-pupil');
    const arm = poster.querySelector<SVGGElement>('.hv-point');
    const stamp = poster.querySelector<HTMLElement>('.hv-stamp');

    // GSAP owns the poster + arm transforms now.
    poster.style.animation = 'none';
    if (arm) arm.style.animation = 'none';
    gsap.set(poster, { yPercent: -50, rotation: 1.5 });
    const float = gsap.to(poster, { y: -8, duration: 4.5, ease: 'sine.inOut', yoyo: true, repeat: -1 });
    const jab = arm
      ? gsap.to(arm, {
          scale: 1.09, transformOrigin: '52px 136px', duration: 0.32,
          ease: 'sine.inOut', yoyo: true, repeat: -1, repeatDelay: 2.1,
        })
      : null;

    const rotTo = gsap.quickTo(poster, 'rotation', { duration: 0.6, ease: 'power3.out' });
    const posXTo = gsap.quickTo(poster, 'x', { duration: 0.6, ease: 'power3.out' });
    const pupilX = pupil ? gsap.quickTo(pupil, 'x', { duration: 0.3, ease: 'power2.out' }) : null;
    const pupilY = pupil ? gsap.quickTo(pupil, 'y', { duration: 0.3, ease: 'power2.out' }) : null;
    const armRot = arm ? gsap.quickTo(arm, 'rotation', { duration: 0.4, ease: 'power2.out' }) : null;

    const onMove = (e: MouseEvent) => {
      const r = poster.getBoundingClientRect();
      const dx = (e.clientX - (r.left + r.width / 2)) / innerWidth;  // -0.5..0.5-ish
      const dy = (e.clientY - (r.top + r.height / 2)) / innerHeight;
      rotTo(1.5 + dx * 3);
      posXTo(dx * 14);
      pupilX?.(Math.max(-4.5, Math.min(4.5, dx * 26)));
      pupilY?.(Math.max(-3.5, Math.min(3.5, dy * 22)));
      armRot?.(Math.max(-9, Math.min(9, dx * 30)));
    };

    // The stamp re-slams if you dare hover it.
    const onStamp = () => {
      gsap.fromTo(stamp!, { scale: 1.5, opacity: 0.4 }, { scale: 1, opacity: 0.92, duration: 0.3, ease: 'power3.out' });
    };

    // Recruiting is serious business — until you hover. Then Bit grins.
    const mouth = poster.querySelector<SVGPathElement>('.hv-mouth');
    const onGrin = () => mouth && gsap.to(mouth, { morphSVG: MOUTH_GRIN, duration: 0.35, ease: 'back.out(2)' });
    const onStern = () => mouth && gsap.to(mouth, { morphSVG: MOUTH_STERN, duration: 0.45, ease: 'power2.inOut' });

    window.addEventListener('mousemove', onMove, { passive: true });
    stamp?.addEventListener('mouseenter', onStamp);
    poster.addEventListener('mouseenter', onGrin);
    poster.addEventListener('mouseleave', onStern);

    window.__hvCleanup = () => {
      window.removeEventListener('mousemove', onMove);
      stamp?.removeEventListener('mouseenter', onStamp);
      poster.removeEventListener('mouseenter', onGrin);
      poster.removeEventListener('mouseleave', onStern);
      float.kill();
      jab?.kill();
      window.__hvCleanup = undefined;
    };
  }

  document.addEventListener('astro:page-load', setupPoster);
  setupPoster();
</script>
