---
import type { CollectionEntry } from 'astro:content';
import { readingTime } from '../lib/reading-time';

type BlogEntry = CollectionEntry<'blog-en'>;

interface Props {
  post: BlogEntry;
  animate?: boolean;
  stagger?: number;
}

const { post, animate = false, stagger } = Astro.props;
const href = `/blog/${post.slug}`;
const dateStr = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric',
});
const tags: string[] = post.data.tags ?? [];
const minutes = readingTime(post.body);
const staggerClass = stagger ? `stagger-${stagger}` : '';
---

<article
  class:list={[
    'card-brutal card-shine group relative p-5 flex flex-col gap-2.5 cursor-pointer',
    animate && 'fade-up',
    staggerClass,
  ]}
  style="background:var(--bg-card)"
  data-tags={tags.join(',')}
>
  <!-- Tag row -->
  {tags.length > 0 && (
    <div class="flex items-center gap-2.5 flex-wrap">
      {tags.map(tag => (
        <span
          class="font-mono text-[10px] px-[10px] py-[3px] rounded-[4px]"
          style="border:1.5px solid var(--fg);color:var(--fg);letter-spacing:0.04em;background:var(--bg-page)"
        >{tag}</span>
      ))}
    </div>
  )}

  <!-- Title — stretched-link makes the entire card clickable -->
  <h3 class="text-[22px] font-bold leading-[1.2]" style="color:var(--fg);font-family:var(--font-display)">
    <a href={href} class="stretched-link">{post.data.title}</a>
  </h3>

  <!-- Description -->
  {post.data.description && (
    <p class="text-sm leading-snug line-clamp-2" style="color:var(--fg-mid)">{post.data.description}</p>
  )}

  <!-- Footer: dashed-top, date · min · Read → — matches ReviewCard rhythm -->
  <div
    class="mt-auto pt-3 flex items-center justify-between gap-3"
    style="border-top:1.5px dashed var(--border)"
  >
    <div class="flex items-center gap-2 font-mono text-[10px]" style="color:var(--fg-muted)">
      <time datetime={post.data.date.toISOString()}>{dateStr}</time>
      <span>·</span>
      <span>{minutes} min</span>
    </div>
    <span class="font-mono text-[10px] font-bold" style="color:var(--accent-text)">Read →</span>
  </div>
</article>
