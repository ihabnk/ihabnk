---
// Persistent fixed-bottom TTS player.
// Rendered once at the layout level with transition:persist so it survives
// view transitions; the inline script is idempotent and uses event delegation
// to bind to per-page #tts-trigger buttons.
---

<div id="tts-bar" class="tts-bar" aria-live="polite" role="region" aria-label="Article audio player" transition:persist="tts-bar">
  <div class="tts-bar-inner">

    <!-- Thumbnail / icon badge (left). Swaps to a pulsing waveform when minimized + playing. -->
    <div class="tts-thumb" aria-hidden="true">
      <svg class="tts-thumb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 18v-6a9 9 0 0 1 18 0v6"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
      </svg>
      <span class="tts-wave">
        <span></span><span></span><span></span><span></span>
      </span>
    </div>

    <!-- Meta: title + subtitle -->
    <div class="tts-meta">
      <span id="tts-bar-title" class="tts-title">Untitled</span>
      <span id="tts-bar-subtitle" class="tts-subtitle">Listen</span>
    </div>

    <!-- Transport controls -->
    <div class="tts-controls">
      <button id="tts-back" class="tts-bar-btn tts-skip" aria-label="Back 10 seconds" title="Back 10s">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12a9 9 0 1 0 3-6.7M3 4v5h5"/>
        </svg>
        <span class="tts-skip-num">10</span>
      </button>

      <button id="tts-bar-toggle" class="tts-bar-play" aria-label="Play">
        <span id="tts-eq-bars" class="tts-eq hidden"><span></span><span></span><span></span></span>
        <svg id="tts-icon-play" viewBox="0 0 24 24" fill="currentColor">
          <path d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347c-.75.412-1.667-.13-1.667-.986V5.653Z"/>
        </svg>
        <svg id="tts-icon-pause" class="hidden" viewBox="0 0 24 24" fill="currentColor">
          <path fill-rule="evenodd" d="M6.75 5.25a.75.75 0 0 1 .75-.75H9a.75.75 0 0 1 .75.75v13.5a.75.75 0 0 1-.75.75H7.5a.75.75 0 0 1-.75-.75V5.25zm7.5 0A.75.75 0 0 1 15 4.5h1.5a.75.75 0 0 1 .75.75v13.5a.75.75 0 0 1-.75.75H15a.75.75 0 0 1-.75-.75V5.25z" clip-rule="evenodd"/>
        </svg>
      </button>

      <button id="tts-forward" class="tts-bar-btn tts-skip" aria-label="Forward 10 seconds" title="Forward 10s">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-3-6.7M21 4v5h-5"/>
        </svg>
        <span class="tts-skip-num">10</span>
      </button>
    </div>

    <!-- Progress row -->
    <div class="tts-progress-row">
      <span id="tts-bar-elapsed" class="tts-time-left">0:00</span>
      <div id="tts-track" class="tts-track" role="slider" aria-label="Seek" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
        <div id="tts-bar-fill" class="tts-fill"></div>
      </div>
      <span id="tts-bar-total" class="tts-time-right">0:00</span>
    </div>

    <!-- Rate selector (desktop only) -->
    <button id="tts-rate-btn" class="tts-rate" aria-label="Playback speed">1×</button>

    <!-- Minimize / expand toggle -->
    <button id="tts-bar-min" class="tts-bar-min" aria-label="Minimize player" title="Minimize">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6"/>
      </svg>
    </button>

    <!-- Close / dismiss -->
    <button id="tts-bar-stop" class="tts-bar-stop" aria-label="Close player">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
      </svg>
    </button>

  </div>
</div>

<script>
  (() => {
    type W = Window & { __ttsInited?: boolean };
    const w = window as W;
    if (w.__ttsInited) return;
    w.__ttsInited = true;

    const TTS_API = '/.netlify/functions/tts';
    const RATES   = [1, 1.25, 1.5, 2, 0.75];
    let rateIdx   = 0;

    const SKIP_SECONDS = 10;

    const ttsBar    = document.getElementById('tts-bar')        as HTMLElement | null;
    const barToggle = document.getElementById('tts-bar-toggle');
    const barStop   = document.getElementById('tts-bar-stop');
    const barMin    = document.getElementById('tts-bar-min');
    const backBtn   = document.getElementById('tts-back');
    const fwdBtn    = document.getElementById('tts-forward');
    const rateBtn   = document.getElementById('tts-rate-btn');
    const barFill   = document.getElementById('tts-bar-fill')   as HTMLElement | null;
    const trackEl   = document.getElementById('tts-track')      as HTMLElement | null;
    const iconPlay  = document.getElementById('tts-icon-play');
    const iconPause = document.getElementById('tts-icon-pause');
    const eqBars    = document.getElementById('tts-eq-bars');

    let minimized = false;

    function applyBodyPadding() {
      if (!visible) { document.body.style.paddingBottom = ''; return; }
      document.body.style.paddingBottom = minimized
        ? 'var(--tts-bar-min-offset, 56px)'
        : 'var(--tts-bar-offset, 96px)';
    }

    function setMinimized(next: boolean) {
      minimized = next;
      ttsBar?.classList.toggle('minimized', next);
      barMin?.setAttribute('aria-label', next ? 'Expand player' : 'Minimize player');
      barMin?.setAttribute('title',      next ? 'Expand'        : 'Minimize');
      applyBodyPadding();
    }

    // Push the bar above mobile browser chrome (Chrome's slide-in URL bar
    // on Android, Safari's floating address bar on iOS). The diff between
    // layout viewport and visual viewport height is the overlap — BUT only
    // when the user isn't pinch-zooming. While zoomed, visualViewport.height
    // also shrinks for unrelated reasons, which would otherwise rocket the
    // bar off the bottom of the screen.
    const setVpOffset = () => {
      const vv = window.visualViewport;
      if (!vv) {
        document.documentElement.style.setProperty('--vp-offset', '0px');
        return;
      }
      // Pinch-zoom guard: only apply the offset when scale is effectively 1.
      if (vv.scale > 1.01 || vv.scale < 0.99) {
        document.documentElement.style.setProperty('--vp-offset', '0px');
        return;
      }
      const raw = window.innerHeight - vv.height;
      // Sub-pixel jitter floor so tiny rounding mismatches don't move the bar.
      const offset = raw > 4 ? raw : 0;
      document.documentElement.style.setProperty('--vp-offset', `${offset}px`);
    };
    window.visualViewport?.addEventListener('resize', setVpOffset);
    window.visualViewport?.addEventListener('scroll', setVpOffset);
    window.addEventListener('resize', setVpOffset);
    setVpOffset();

    type VisualState = 'idle' | 'buffering' | 'playing' | 'paused' | 'ended';
    type CancelToken = { cancelled: boolean };

    let state: VisualState = 'idle';
    let visible = false;                          // bar visibility, separate from playback state
    let activeRun: CancelToken | null = null;     // current playback "generation" token
    let currentAudio: HTMLAudioElement | null = null;
    let timerInterval: number | undefined;
    let totalDuration = 0;
    let elapsed       = 0;
    let currentPath: string | null = null;

    let paragraphs: HTMLParagraphElement[] = [];
    let paragraphOffsets: number[] = [];
    let totalChars     = 0;
    let activeParaIdx  = -1;

    function setActiveParagraph(idx: number) {
      if (idx === activeParaIdx) return;
      activeParaIdx = idx;
      paragraphs.forEach((p, i) => p.classList.toggle('reading-now', i === idx));
      const el = paragraphs[idx];
      if (el && el.isConnected) {
        const rect = el.getBoundingClientRect();
        const inView = rect.top > 80 && rect.bottom < window.innerHeight - 100;
        if (!inView) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }

    function clearActiveParagraph() {
      if (activeParaIdx === -1) return;
      paragraphs.forEach(p => p.classList.remove('reading-now'));
      activeParaIdx = -1;
    }

    function indexParagraphs(article: HTMLElement) {
      paragraphs = Array.from(article.querySelectorAll<HTMLParagraphElement>('p'));
      paragraphOffsets = [];
      let acc = 0;
      for (const p of paragraphs) {
        paragraphOffsets.push(acc);
        acc += cleanText(p.textContent ?? '').length + 1;
      }
      totalChars = acc;
      activeParaIdx = -1;
    }

    function updateActiveFromChar(currentChar: number) {
      if (!paragraphs.length) return;
      let idx = 0;
      for (let i = paragraphs.length - 1; i >= 0; i--) {
        if (paragraphOffsets[i] <= currentChar) { idx = i; break; }
      }
      setActiveParagraph(idx);
    }

    function fmt(s: number): string {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    function updateTriggerUI() {
      const triggerBtn   = document.getElementById('tts-trigger');
      const triggerLabel = document.getElementById('tts-trigger-label');
      if (!triggerBtn || !triggerLabel) return;
      const onPlayingPage = currentPath !== null && location.pathname === currentPath;
      const active        = state !== 'idle' && onPlayingPage;
      triggerBtn.classList.toggle('active', active);
      triggerLabel.textContent = active ? 'Listening' : 'Listen to article';
    }

    function setVisual(next: VisualState) {
      state = next;
      if (!ttsBar) return;

      // Visibility is owned by `visible`, not by playback state — the bar
      // stays mounted across pause/end/article-switch and only hides when
      // the user explicitly dismisses it via the X button.
      ttsBar.classList.toggle('active', visible);

      ttsBar.classList.toggle('state-playing',   next === 'playing');
      ttsBar.classList.toggle('state-buffering', next === 'buffering');
      ttsBar.classList.toggle('state-paused',    next === 'paused');
      ttsBar.classList.toggle('state-ended',     next === 'ended');

      const isPlaying   = next === 'playing';
      const isBuffering = next === 'buffering';

      iconPlay ?.classList.toggle('hidden',  isPlaying || isBuffering);
      iconPause?.classList.toggle('hidden', !isPlaying);
      eqBars   ?.classList.toggle('hidden', !isBuffering);

      applyBodyPadding();

      if (isPlaying) {
        barToggle?.setAttribute('aria-label', 'Pause');
      } else {
        barToggle?.setAttribute('aria-label', 'Play');
      }

      updateTriggerUI();
    }

    function updateTimer() {
      const elapsedEl = document.getElementById('tts-bar-elapsed');
      const totalEl   = document.getElementById('tts-bar-total');
      if (!barFill) return;
      const total = totalDuration || 1;
      const pct   = Math.min((elapsed / total) * 100, 100);
      barFill.style.width = `${pct}%`;
      if (elapsedEl) elapsedEl.textContent = fmt(elapsed);
      if (totalEl)   totalEl.textContent   = fmt(total);
      trackEl?.setAttribute('aria-valuenow', String(Math.round(pct)));
    }

    function startTimer(run: CancelToken) {
      clearInterval(timerInterval);
      timerInterval = window.setInterval(() => {
        if (run.cancelled) { clearInterval(timerInterval); return; }
        if (state !== 'playing') return;
        elapsed = Math.min(elapsed + 0.25, totalDuration || elapsed + 0.25);
        updateTimer();
      }, 250);
    }

    function cleanText(raw: string): string {
      return raw
        .replace(/```[\s\S]*?```/g, '')
        .replace(/`[^`]+`/g, '')
        .replace(/https?:\/\/\S+/g, '')
        .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
        .replace(/#+\s/g, '')
        .replace(/[*_]{1,2}([^*_]+)[*_]{1,2}/g, '$1')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function chunkText(text: string, max = 4000): string[] {
      const chunks: string[] = [];
      let rest = text;
      while (rest.length > max) {
        let cut = rest.lastIndexOf('. ', max);
        if (cut < 0) cut = max;
        chunks.push(rest.slice(0, cut + 1).trim());
        rest = rest.slice(cut + 1).trim();
      }
      if (rest) chunks.push(rest);
      return chunks;
    }

    // Cancel the in-flight playback run and clear all transient state, but
    // do NOT change visibility — the bar stays mounted unless dismiss() is
    // called. Crucially, marking activeRun.cancelled = true prevents the
    // previous async chain from racing the new one and writing stale state
    // (the "play-button-turns-white-and-pause-makes-it-disappear" bug).
    function cancelPlayback() {
      if (activeRun) {
        activeRun.cancelled = true;
        activeRun = null;
      }
      clearInterval(timerInterval);
      try { speechSynthesis.cancel(); } catch {}
      if (currentAudio) {
        currentAudio.onended = null;
        currentAudio.onerror = null;
        currentAudio.pause();
        currentAudio.src = '';
        currentAudio = null;
      }
      elapsed = 0;
      totalDuration = 0;
      if (barFill) barFill.style.width = '0%';
      const elapsedEl = document.getElementById('tts-bar-elapsed');
      const totalEl   = document.getElementById('tts-bar-total');
      if (elapsedEl) elapsedEl.textContent = '0:00';
      if (totalEl)   totalEl.textContent   = '0:00';
      clearActiveParagraph();
      paragraphs = [];
      paragraphOffsets = [];
    }

    function dismiss() {
      cancelPlayback();
      currentPath = null;
      visible = false;
      setVisual('idle');
    }

    async function playWithAzure(text: string, run: CancelToken) {
      const chunks   = chunkText(text);
      const totalLen = chunks.reduce((s, c) => s + c.length, 0);
      let doneLen    = 0;
      let pace       = 0;

      for (const chunk of chunks) {
        if (run.cancelled) return;
        const res = await fetch(TTS_API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: chunk, lang: 'en' }),
        });
        if (run.cancelled) return;
        if (!res.ok) throw new Error(`api-${res.status}`);
        const blob = await res.blob();
        if (run.cancelled) return;
        const url   = URL.createObjectURL(blob);
        const audio = new Audio(url);
        audio.playbackRate = RATES[rateIdx];
        currentAudio = audio;

        audio.addEventListener('loadedmetadata', () => {
          if (run.cancelled) return;
          const chunkDur = audio.duration / audio.playbackRate;
          pace = chunkDur / Math.max(chunk.length, 1);
          totalDuration = pace * totalLen;
          if (state === 'buffering') setVisual('playing');
          startTimer(run);
        });

        audio.addEventListener('timeupdate', () => {
          if (run.cancelled) return;
          if (!audio.duration) return;
          const chunkPct    = audio.currentTime / audio.duration;
          const currentChar = doneLen + chunk.length * chunkPct;
          const chunkElapsedReal = audio.currentTime / audio.playbackRate;
          elapsed = (doneLen * pace) + chunkElapsedReal;
          updateTimer();
          updateActiveFromChar(currentChar);
        });

        await new Promise<void>(resolve => {
          audio.onended = () => { URL.revokeObjectURL(url); doneLen += chunk.length; resolve(); };
          audio.onerror = () => { URL.revokeObjectURL(url); resolve(); };
          audio.play().catch(resolve);
        });
        if (run.cancelled) return;
      }

      if (run.cancelled) return;
      clearInterval(timerInterval);
      if (barFill) barFill.style.width = '100%';
      setTimeout(() => { if (!run.cancelled && barFill) barFill.style.width = '0%'; }, 800);
      clearActiveParagraph();
      setVisual('ended');
    }

    function playWithWebSpeech(text: string, run: CancelToken) {
      if (!('speechSynthesis' in window)) { dismiss(); return; }
      const utt = new SpeechSynthesisUtterance(text);
      utt.lang  = 'en-US';
      utt.rate  = RATES[rateIdx] * 0.92;
      totalDuration = text.length * 0.06;
      setVisual('playing');
      startTimer(run);
      utt.onboundary = (event) => {
        if (run.cancelled) return;
        if (typeof event.charIndex === 'number') {
          updateActiveFromChar(event.charIndex);
          elapsed = (event.charIndex / Math.max(text.length, 1)) * totalDuration;
          updateTimer();
        }
      };
      utt.onend = () => {
        if (run.cancelled) return;
        clearInterval(timerInterval);
        clearActiveParagraph();
        setVisual('ended');
      };
      speechSynthesis.speak(utt);
    }

    function bindMeta() {
      const titleEl    = document.getElementById('tts-bar-title');
      const subtitleEl = document.getElementById('tts-bar-subtitle');
      const h1         = document.querySelector<HTMLElement>('.article-headline');
      const kicker     = document.querySelector<HTMLElement>('.article-kicker');

      const title = h1?.textContent?.trim() ||
                    document.title.split(' | ')[0] ||
                    'Article';
      const subtitle = kicker?.textContent?.trim() || 'ihabnk · audio';

      if (titleEl)    titleEl.textContent    = title;
      if (subtitleEl) subtitleEl.textContent = subtitle;
    }

    async function startForCurrentArticle() {
      const article = document.getElementById('article-body');
      if (!article) return;

      cancelPlayback();         // tear down any previous run before starting a new one
      bindMeta();
      indexParagraphs(article);
      currentPath = location.pathname;

      const run: CancelToken = { cancelled: false };
      activeRun = run;

      visible = true;
      setVisual('buffering');

      const text = cleanText(article.textContent?.trim() ?? '');
      try {
        await playWithAzure(text, run);
      } catch {
        if (!run.cancelled) playWithWebSpeech(text, run);
      }
    }

    /* ── Trigger (event delegation) ── */
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (!target?.closest('#tts-trigger')) return;
      // Same article and already active → user is asking to dismiss it
      if (state !== 'idle' && currentPath === location.pathname) { dismiss(); return; }
      // Different article (or idle) → start a fresh playback
      startForCurrentArticle();
    });

    /* ── Play / Pause ── */
    barToggle?.addEventListener('click', () => {
      if (state === 'playing') {
        if (currentAudio) currentAudio.pause();
        else { try { speechSynthesis.pause(); } catch {} }
        clearInterval(timerInterval);
        setVisual('paused');
      } else if (state === 'paused') {
        if (currentAudio) currentAudio.play().catch(() => {});
        else { try { speechSynthesis.resume(); } catch {} }
        if (activeRun) startTimer(activeRun);
        setVisual('playing');
      } else if (state === 'ended') {
        // Restart playback for the current article. Bar stays visible.
        if (document.getElementById('article-body')) startForCurrentArticle();
      }
    });

    /* ── Skip ── */
    backBtn?.addEventListener('click', () => {
      if (currentAudio) currentAudio.currentTime = Math.max(0, currentAudio.currentTime - SKIP_SECONDS);
      elapsed = Math.max(0, elapsed - SKIP_SECONDS);
      updateTimer();
    });
    fwdBtn?.addEventListener('click', () => {
      if (currentAudio) currentAudio.currentTime = Math.min(currentAudio.duration, currentAudio.currentTime + SKIP_SECONDS);
      elapsed = Math.min(totalDuration, elapsed + SKIP_SECONDS);
      updateTimer();
    });

    /* ── Rate ── */
    rateBtn?.addEventListener('click', () => {
      rateIdx = (rateIdx + 1) % RATES.length;
      const rate = RATES[rateIdx];
      if (rateBtn) rateBtn.textContent = `${rate}×`;
      rateBtn?.classList.toggle('boosted', rate !== 1);
      if (currentAudio) currentAudio.playbackRate = rate;
    });

    /* ── Seek ── */
    trackEl?.addEventListener('click', (e) => {
      const rect = trackEl.getBoundingClientRect();
      const pct  = (e.clientX - rect.left) / rect.width;
      elapsed    = pct * totalDuration;
      if (currentAudio && currentAudio.duration) {
        currentAudio.currentTime = pct * currentAudio.duration;
      }
      updateTimer();
    });

    /* ── Stop (X button) — the only thing that hides the bar ── */
    barStop?.addEventListener('click', () => dismiss());

    /* ── Minimize toggle ── */
    barMin?.addEventListener('click', () => setMinimized(!minimized));

    /* ── View-transition lifecycle ── */
    document.addEventListener('astro:after-swap', () => {
      applyBodyPadding();
      updateTriggerUI();
      if (currentPath && location.pathname === currentPath) {
        const article = document.getElementById('article-body');
        if (article) indexParagraphs(article);
      } else {
        clearActiveParagraph();
      }
    });
  })();
</script>
