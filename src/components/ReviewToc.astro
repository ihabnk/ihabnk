---
interface TocItem { label: string; anchor: string }

interface Props {
  items: TocItem[];
}

const { items } = Astro.props;
---

<nav
  class="card-brutal mb-10 p-5"
  style="background:var(--bg-card)"
  aria-label="Table of contents"
>
  <span class="section-label mb-3 block">// contents</span>
  <ol class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1.5">
    {items.map((item, i) => (
      <li class="flex items-baseline gap-2.5">
        <span
          class="font-mono text-[10px] font-bold tabular-nums"
          style="color:var(--fg-muted);min-width:1.6em"
          aria-hidden="true"
        >{String(i + 1).padStart(2, '0')}</span>
        <a
          href={`#${item.anchor}`}
          class="font-mono text-[13px] transition-colors duration-150 hover:underline"
          style="color:var(--accent-text)"
        >{item.label}</a>
      </li>
    ))}
  </ol>
</nav>
