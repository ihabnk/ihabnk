---
/**
 * ArticleArt — per-article SVG illustration in the site's brutalist grammar.
 * Solid fills, hard 2px borders, offset block shadows, mono captions only.
 *
 *   slug    — content slug; selects one of 8 variants (falls back to generic)
 *   variant — 'card' | 'row' | 'hero' (placement; controls outer styling)
 */

interface Props {
  slug: string;
  variant?: 'card' | 'row' | 'hero';
  class?: string;
}

const { slug, variant = 'card', class: className = '' } = Astro.props;

// Map slug → art id. Unknown slugs hash to the generic variant.
const variantBySlug: Record<string, string> = {
  'ai-changing-qa-role':        'qa-to-ai',
  'digital-privacy-ai-era':     'privacy',
  'evals-are-the-new-tests':    'evals',
  'product-thinking-for-ai-tools': 'demo-vs-daily',
  'scrum-age-of-ai-tools':      'sprint-cycle',
  'self-testing-agent-python':  'agent-loop',
  'shipping-llm-features-in-prod': 'pipeline',
  'why-quality-is-the-bottleneck': 'funnel',
};
const art = variantBySlug[slug] ?? 'generic';
---

<div class:list={['article-art', `article-art--${variant}`, `art-${art}`, className]} aria-hidden="true">
  <svg viewBox="0 0 320 180" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
    {/* Card background */}
    <rect x="0" y="0" width="320" height="180" style="fill:var(--bg-surface)"/>

    {/* Dotted grid backdrop */}
    <pattern id={`grid-${slug}`} x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="1" style="fill:var(--fg);opacity:0.10"/>
    </pattern>
    <rect x="0" y="0" width="320" height="180" fill={`url(#grid-${slug})`}/>

    {/* Variant body */}
    {art === 'qa-to-ai' && (
      <g style="font-family:var(--font-mono)">
        {/* Manual checklist (left) — 3 lines, last 2 filled */}
        <g transform="translate(24,38)">
          <rect x="0" y="0" width="14" height="14" rx="1" style="fill:none;stroke:var(--fg);stroke-width:2"/>
          <line x1="22" y1="7" x2="74" y2="7" style="stroke:var(--fg);stroke-width:2"/>
          <rect x="0" y="26" width="14" height="14" rx="1" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <polyline points="3,33 6,36 11,30" style="fill:none;stroke:var(--on-accent);stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round"/>
          <line x1="22" y1="33" x2="74" y2="33" style="stroke:var(--fg);stroke-width:2"/>
          <rect x="0" y="52" width="14" height="14" rx="1" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <polyline points="3,59 6,62 11,56" style="fill:none;stroke:var(--on-accent);stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round"/>
          <line x1="22" y1="59" x2="74" y2="59" style="stroke:var(--fg);stroke-width:2"/>
        </g>

        {/* Arrow bridge */}
        <g transform="translate(130,80)">
          <line class="aa-flow" x1="0" y1="10" x2="38" y2="10" style="stroke:var(--accent-text);stroke-width:3;stroke-dasharray:6 4"/>
          <polygon points="38,2 50,10 38,18" style="fill:var(--accent-text)"/>
        </g>

        {/* Node graph (right) */}
        <g transform="translate(202,40)">
          <line x1="14" y1="14" x2="64" y2="42" style="stroke:var(--fg);stroke-width:2"/>
          <line x1="64" y1="42" x2="14" y2="78" style="stroke:var(--fg);stroke-width:2"/>
          <line x1="14" y1="14" x2="14" y2="78" style="stroke:var(--fg);stroke-width:2"/>
          <circle cx="14" cy="14" r="9" style="fill:var(--bg-page);stroke:var(--fg);stroke-width:2"/>
          <circle cx="14" cy="78" r="9" style="fill:var(--bg-page);stroke:var(--fg);stroke-width:2"/>
          <circle class="aa-pulse" cx="64" cy="42" r="11" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <circle cx="64" cy="42" r="4" style="fill:var(--on-accent)"/>
        </g>

        {/* Caption */}
        <text x="24" y="160" style="font-size:9px;fill:var(--fg-muted);letter-spacing:0.06em">// manual → ai-augmented</text>
      </g>
    )}

    {art === 'privacy' && (
      <g style="font-family:var(--font-mono)">
        {/* Eye lens (left) */}
        <g transform="translate(40,90)">
          <path d="M-30,0 Q0,-30 30,0 Q0,30 -30,0 Z" style="fill:var(--bg-page);stroke:var(--fg);stroke-width:2"/>
          <circle class="aa-iris" cx="0" cy="0" r="11" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <circle class="aa-iris-dot" cx="0" cy="0" r="4" style="fill:var(--on-accent)"/>
          <line class="aa-strike" x1="-22" y1="0" x2="30" y2="0" style="stroke:var(--pop-red);stroke-width:3"/>
        </g>

        {/* Redacted prompt tokens (top right) */}
        <g transform="translate(110,38)">
          <rect x="0" y="0" width="40" height="10" rx="1" style="fill:var(--fg);stroke:var(--fg);stroke-width:2"/>
          <rect x="46" y="0" width="62" height="10" rx="1" style="fill:none;stroke:var(--fg);stroke-width:2"/>
          <rect x="114" y="0" width="34" height="10" rx="1" style="fill:var(--fg);stroke:var(--fg);stroke-width:2"/>
          <rect x="0" y="18" width="74" height="10" rx="1" style="fill:none;stroke:var(--fg);stroke-width:2"/>
          <rect x="80" y="18" width="50" height="10" rx="1" style="fill:var(--fg);stroke:var(--fg);stroke-width:2"/>
        </g>

        {/* Lock badge (right) */}
        <g transform="translate(220,82)">
          <rect x="0" y="14" width="44" height="34" rx="2" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <path d="M10,14 V8 a12,12 0 0 1 24,0 V14" style="fill:none;stroke:var(--fg);stroke-width:2.5"/>
          <circle cx="22" cy="30" r="3.5" style="fill:var(--on-accent)"/>
          <line x1="22" y1="30" x2="22" y2="40" style="stroke:var(--on-accent);stroke-width:2.4"/>
        </g>

        <text x="24" y="160" style="font-size:9px;fill:var(--fg-muted);letter-spacing:0.06em">// data: scoped · logs: redacted</text>
      </g>
    )}

    {art === 'evals' && (
      <g style="font-family:var(--font-mono)">
        {/* Axis */}
        <line x1="36" y1="46" x2="36" y2="128" style="stroke:var(--fg);stroke-width:2"/>
        <line x1="36" y1="128" x2="290" y2="128" style="stroke:var(--fg);stroke-width:2"/>
        {/* Tick marks */}
        <line x1="32" y1="60"  x2="38" y2="60"  style="stroke:var(--fg);stroke-width:1.5"/>
        <line x1="32" y1="80"  x2="38" y2="80"  style="stroke:var(--fg);stroke-width:1.5"/>
        <line x1="32" y1="100" x2="38" y2="100" style="stroke:var(--fg);stroke-width:1.5"/>

        {/* Bars — animated as a wave (transform-origin: bottom via fill-box) */}
        <rect class="aa-bar aa-bar-1" x="56"  y="48"  width="22" height="80" style="fill:none;stroke:var(--fg);stroke-width:2"/>
        <rect class="aa-bar aa-bar-2" x="88"  y="48"  width="22" height="80" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
        <rect class="aa-bar aa-bar-3" x="120" y="48"  width="22" height="80" style="fill:none;stroke:var(--fg);stroke-width:2"/>
        <rect class="aa-bar aa-bar-4" x="152" y="48"  width="22" height="80" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
        <rect class="aa-bar aa-bar-5" x="184" y="48"  width="22" height="80" style="fill:none;stroke:var(--fg);stroke-width:2"/>
        <rect class="aa-bar aa-bar-6" x="216" y="48"  width="22" height="80" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
        <rect class="aa-bar aa-bar-7" x="248" y="48"  width="22" height="80" style="fill:none;stroke:var(--fg);stroke-width:2"/>

        {/* Big check (draws in) */}
        <polyline class="aa-draw-check" points="240,42 252,54 280,26"
                  style="fill:none;stroke:var(--accent-text);stroke-width:4;stroke-linecap:round;stroke-linejoin:round;stroke-dasharray:60;stroke-dashoffset:60"/>

        <text x="36" y="160" style="font-size:9px;fill:var(--fg-muted);letter-spacing:0.06em">// score: 0.94 · regressions: 0</text>
      </g>
    )}

    {art === 'demo-vs-daily' && (
      <g style="font-family:var(--font-mono)">
        {/* DEMO card — full */}
        <g transform="translate(36,34)">
          <rect x="0" y="0" width="92" height="100" rx="2" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <text x="10" y="22" style="font-size:11px;fill:var(--on-accent);font-weight:700;letter-spacing:0.08em">DEMO</text>
          <rect x="10" y="34" width="72" height="6" style="fill:var(--on-accent);opacity:0.6"/>
          <rect x="10" y="46" width="58" height="6" style="fill:var(--on-accent);opacity:0.6"/>
          <rect x="10" y="58" width="68" height="6" style="fill:var(--on-accent);opacity:0.6"/>
          <rect x="10" y="70" width="46" height="6" style="fill:var(--on-accent);opacity:0.6"/>
          <text x="10" y="92" style="font-size:9px;fill:var(--on-accent);font-weight:700">★ wow</text>
        </g>

        {/* Decline arrow between cards */}
        <path class="aa-decline" d="M138,52 Q160,82 178,108" style="fill:none;stroke:var(--pop-red);stroke-width:2.4;stroke-dasharray:5 4"/>
        <polygon points="172,100 180,114 184,98" style="fill:var(--pop-red)"/>

        {/* DAILY card — sparse */}
        <g transform="translate(192,52)">
          <rect x="0" y="0" width="92" height="82" rx="2" style="fill:var(--bg-page);stroke:var(--fg);stroke-width:2"/>
          <text x="10" y="22" style="font-size:11px;fill:var(--fg);font-weight:700;letter-spacing:0.08em">DAILY</text>
          <rect x="10" y="34" width="40" height="6" style="fill:var(--fg);opacity:0.35"/>
          <rect x="10" y="46" width="22" height="6" style="fill:var(--fg);opacity:0.35"/>
          <text x="10" y="70" style="font-size:9px;fill:var(--fg-muted)">↳ habit</text>
        </g>

        <text x="36" y="160" style="font-size:9px;fill:var(--fg-muted);letter-spacing:0.06em">// wow ≠ retain</text>
      </g>
    )}

    {art === 'sprint-cycle' && (
      <g style="font-family:var(--font-mono)">
        {/* Circular cycle */}
        <g transform="translate(160,90)">
          <circle class="aa-spin-dash" cx="0" cy="0" r="52" style="fill:none;stroke:var(--fg);stroke-width:2;stroke-dasharray:4 4"/>
          {/* Arrow at top */}
          <polygon points="6,-52 -6,-46 -6,-58" style="fill:var(--accent-text)"/>

          {/* Four station dots — top one pulses */}
          <circle class="aa-pulse" cx="0"   cy="-52" r="8" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <circle cx="52"  cy="0"   r="6" style="fill:var(--bg-page);stroke:var(--fg);stroke-width:2"/>
          <circle cx="0"   cy="52"  r="6" style="fill:var(--bg-page);stroke:var(--fg);stroke-width:2"/>
          <circle cx="-52" cy="0"   r="6" style="fill:var(--bg-page);stroke:var(--fg);stroke-width:2"/>

          {/* Center label */}
          <text x="0" y="-2" text-anchor="middle" style="font-size:10px;fill:var(--fg);font-weight:700;letter-spacing:0.06em">SPRINT</text>
          <text x="0" y="12" text-anchor="middle" style="font-size:9px;fill:var(--accent-text);letter-spacing:0.06em">#01</text>
        </g>

        {/* Station labels */}
        <text x="160" y="28"  text-anchor="middle" style="font-size:8px;fill:var(--fg-muted);font-family:var(--font-mono)">PLAN</text>
        <text x="222" y="94"  style="font-size:8px;fill:var(--fg-muted);font-family:var(--font-mono)">BUILD</text>
        <text x="160" y="158" text-anchor="middle" style="font-size:8px;fill:var(--fg-muted);font-family:var(--font-mono)">SHIP</text>
        <text x="76"  y="94"  text-anchor="end" style="font-size:8px;fill:var(--fg-muted);font-family:var(--font-mono)">REVIEW</text>
      </g>
    )}

    {art === 'agent-loop' && (
      <g style="font-family:var(--font-mono)">
        {/* Main function box */}
        <rect x="98" y="62" width="124" height="56" rx="2" style="fill:var(--bg-page);stroke:var(--fg);stroke-width:2"/>
        <text x="160" y="86" text-anchor="middle" style="font-size:11px;fill:var(--fg);font-weight:700">def agent()</text>
        <text x="160" y="104" text-anchor="middle" style="font-size:9px;fill:var(--accent-text)">while not done:</text>

        {/* Input arrow */}
        <line x1="40" y1="90" x2="90" y2="90" style="stroke:var(--fg);stroke-width:2"/>
        <polygon points="90,84 98,90 90,96" style="fill:var(--fg)"/>
        <text x="40" y="80" style="font-size:8px;fill:var(--fg-muted)">prompt</text>

        {/* Output arrow */}
        <line x1="222" y1="90" x2="280" y2="90" style="stroke:var(--fg);stroke-width:2"/>
        <polygon points="280,84 288,90 280,96" style="fill:var(--fg)"/>
        <text x="240" y="80" style="font-size:8px;fill:var(--fg-muted)">result</text>

        {/* Loop arrow — dashed flow */}
        <path class="aa-loop-arrow" d="M275,98 Q300,140 200,140 Q140,140 130,118"
              style="fill:none;stroke:var(--accent-text);stroke-width:2.4;stroke-dasharray:6 4"/>
        <polygon points="124,114 130,124 134,114" style="fill:var(--accent-text)"/>
        <text x="190" y="155" text-anchor="middle" style="font-size:8px;fill:var(--accent-text);letter-spacing:0.06em">retry · learn</text>

        {/* Test sparks above — stagger blink */}
        <g transform="translate(118,32)">
          <rect class="aa-spark aa-spark-1" x="0"  y="0" width="22" height="14" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <rect class="aa-spark aa-spark-2" x="34" y="0" width="22" height="14" style="fill:none;stroke:var(--fg);stroke-width:2"/>
          <rect class="aa-spark aa-spark-3" x="68" y="0" width="22" height="14" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
        </g>
      </g>
    )}

    {art === 'pipeline' && (
      <g style="font-family:var(--font-mono)">
        {/* Three boxes */}
        <rect x="30"  y="70" width="64" height="40" rx="2" style="fill:var(--bg-page);stroke:var(--fg);stroke-width:2"/>
        <text x="62" y="94" text-anchor="middle" style="font-size:10px;fill:var(--fg);font-weight:700">prompt</text>

        <rect class="aa-llm" x="128" y="70" width="64" height="40" rx="2" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
        <text x="160" y="94" text-anchor="middle" style="font-size:10px;fill:var(--on-accent);font-weight:700">LLM</text>

        <rect x="226" y="70" width="64" height="40" rx="2" style="fill:var(--bg-page);stroke:var(--fg);stroke-width:2"/>
        <text x="258" y="94" text-anchor="middle" style="font-size:10px;fill:var(--fg);font-weight:700">user</text>

        {/* Arrows */}
        <line x1="94"  y1="90" x2="124" y2="90" style="stroke:var(--fg);stroke-width:2"/>
        <polygon points="124,84 132,90 124,96" style="fill:var(--fg)"/>
        <line x1="192" y1="90" x2="222" y2="90" style="stroke:var(--fg);stroke-width:2"/>
        <polygon points="222,84 230,90 222,96" style="fill:var(--fg)"/>

        {/* Retry loop above LLM */}
        <path d="M138,68 Q140,40 160,40 Q180,40 182,68" style="fill:none;stroke:var(--accent-text);stroke-width:2"/>
        <polygon points="178,64 184,72 188,62" style="fill:var(--accent-text)"/>
        <text x="160" y="32" text-anchor="middle" style="font-size:8px;fill:var(--accent-text);letter-spacing:0.06em">retry</text>

        {/* Latency meter below */}
        <rect x="30"  y="132" width="260" height="8" rx="1" style="fill:none;stroke:var(--fg);stroke-width:2"/>
        <rect class="aa-meter" x="32"  y="134" width="168" height="4" style="fill:var(--accent);transform-origin:0 0"/>
        <text x="30"  y="158" style="font-size:8px;fill:var(--fg-muted);letter-spacing:0.06em">// p95: 2.4s · cost: $0.003</text>
      </g>
    )}

    {art === 'funnel' && (
      <g style="font-family:var(--font-mono)">
        {/* Input row of dots */}
        <g transform="translate(0,46)">
          {[28, 56, 84, 112, 140, 168, 196, 224, 252, 280].map(x => (
            <circle cx={x} cy="0" r="5" style="fill:var(--fg)"/>
          ))}
        </g>

        {/* Funnel walls */}
        <line x1="28"  y1="58" x2="130" y2="106" style="stroke:var(--fg);stroke-width:2"/>
        <line x1="292" y1="58" x2="190" y2="106" style="stroke:var(--fg);stroke-width:2"/>

        {/* Bottleneck channel */}
        <rect x="130" y="106" width="60" height="14" style="fill:none;stroke:var(--fg);stroke-width:2"/>
        <g class="aa-x">
          <line x1="130" y1="106" x2="190" y2="120" style="stroke:var(--pop-red);stroke-width:2.4"/>
          <line x1="190" y1="106" x2="130" y2="120" style="stroke:var(--pop-red);stroke-width:2.4"/>
        </g>

        {/* Output row — fewer dots, pulse together */}
        <g transform="translate(0,140)">
          <circle class="aa-pulse" cx="146" cy="0" r="5" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
          <circle class="aa-pulse" cx="174" cy="0" r="5" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
        </g>

        <text x="24" y="170" style="font-size:9px;fill:var(--fg-muted);letter-spacing:0.06em">// throughput ≠ quality</text>
      </g>
    )}

    {art === 'generic' && (
      <g style="font-family:var(--font-mono)">
        <rect x="36" y="42" width="80" height="80" rx="2" style="fill:var(--accent);stroke:var(--fg);stroke-width:2"/>
        <rect x="100" y="58" width="80" height="80" rx="2" style="fill:var(--bg-page);stroke:var(--fg);stroke-width:2"/>
        <circle cx="232" cy="82" r="32" style="fill:none;stroke:var(--fg);stroke-width:2"/>
        <circle cx="232" cy="82" r="14" style="fill:var(--accent)"/>
        <text x="36" y="160" style="font-size:9px;fill:var(--fg-muted);letter-spacing:0.06em">// notes from the field</text>
      </g>
    )}
  </svg>
</div>

<style>
  .article-art {
    position: relative;
    width: 100%;
    overflow: hidden;
    border: 2px solid var(--fg);
    border-radius: 4px;
    background: var(--bg-surface);
  }

  /* Inner SVG fills the box */
  .article-art svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Card thumbnail — sits at top of BlogCard (BlogCard uses p-5 = 20px) */
  .article-art--card {
    aspect-ratio: 16 / 9;
    margin: -20px -20px 6px;
    width: calc(100% + 40px);
    border-left: none;
    border-right: none;
    border-top: none;
    border-bottom: 2px solid var(--fg);
    border-radius: 0;
  }

  /* Row thumbnail — small square-ish chip on left of BlogRow */
  .article-art--row {
    aspect-ratio: 16 / 9;
    width: 132px;
    flex-shrink: 0;
  }
  @media (max-width: 640px) {
    .article-art--row { display: none; }
  }

  /* Hero banner — wide above article headline */
  .article-art--hero {
    aspect-ratio: 21 / 8;
    margin-bottom: 28px;
    box-shadow: 6px 6px 0 var(--fg);
  }
  @media (max-width: 640px) {
    .article-art--hero {
      aspect-ratio: 16 / 9;
      box-shadow: 4px 4px 0 var(--fg);
    }
  }

  /* ────────────────────────────────────────────────────────── */
  /* Variant animations — same grammar as HeroVisual            */
  /* ────────────────────────────────────────────────────────── */

  /* Helpers: use fill-box so transform-origin works on SVG primitives */
  .aa-pulse, .aa-iris, .aa-bar, .aa-spark, .aa-llm, .aa-x {
    transform-box: fill-box;
    transform-origin: center;
  }
  .aa-bar { transform-origin: center bottom; }
  .aa-meter { transform-box: fill-box; transform-origin: left center; }

  /* Subtle scale/opacity pulse — used by amber accents */
  .aa-pulse {
    animation: aa-pulse 2.6s ease-in-out infinite;
  }
  @keyframes aa-pulse {
    0%, 100% { transform: scale(1);     opacity: 1; }
    50%      { transform: scale(1.18);  opacity: 0.78; }
  }

  /* Dashed arrow flow — moves the dasharray pattern */
  .aa-flow, .aa-loop-arrow, .aa-decline {
    animation: aa-flow 1.6s linear infinite;
  }
  @keyframes aa-flow {
    to { stroke-dashoffset: -20; }
  }

  /* Spinning dashed circle (sprint cycle) */
  .aa-spin-dash {
    animation: aa-spin-dash 14s linear infinite;
  }
  @keyframes aa-spin-dash {
    to { stroke-dashoffset: -200; }
  }

  /* Eye blink — fast double-blink loop, otherwise still */
  .aa-iris {
    animation: aa-iris-blink 5.4s ease-in-out infinite;
  }
  @keyframes aa-iris-blink {
    0%, 88%, 96%, 100% { transform: scaleY(1); }
    92%                { transform: scaleY(0.12); }
  }
  .aa-strike {
    animation: aa-strike 5.4s ease-in-out infinite;
  }
  @keyframes aa-strike {
    0%, 100% { opacity: 1; }
    44%, 56% { opacity: 0.25; }
  }

  /* Wave of bars (evals) — staggered scale-Y from baseline */
  .aa-bar { animation: aa-bar-wave 2.8s ease-in-out infinite; }
  .aa-bar-1 { animation-delay: 0.0s; }
  .aa-bar-2 { animation-delay: 0.1s; }
