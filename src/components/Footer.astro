  {
    label: 'GitHub',
    href:  'https://github.com/ihabnk',
    svg:   '<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>',
    viewBox: '0 0 16 16',
  },
  {
    label: 'LinkedIn',
    href:  'https://linkedin.com/in/ihabnk',
    svg:   '<path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/>',
    viewBox: '0 0 24 24',
  },
  {
    label: 'Bluesky',
    href:  'https://bsky.app/profile/ihabnk.org',
    svg:   '<path d="M135.72 44.03c66.5 49.92 138.02 151.14 164.28 205.46 26.26-54.32 97.78-155.54 164.28-205.46 47.97-36.02 125.72-63.88 125.72 24.83 0 17.71-10.15 148.79-16.11 170.07-20.7 73.98-96.16 92.83-163.25 81.42 117.25 19.95 147.13 86.05 82.69 152.16-122.34 125.55-175.83-31.5-189.53-71.74-2.51-7.38-3.69-10.83-3.7-7.9-0.01-2.93-1.19 0.52-3.7 7.9-13.69 40.24-67.19 197.29-189.53 71.74-64.43-66.11-34.55-132.21 82.69-152.16-67.09 11.41-142.55-7.44-163.25-81.42-5.96-21.29-16.11-152.36-16.11-170.07 0-88.7 77.75-60.85 125.72-24.83z"/>',
    viewBox: '0 0 600 530',
  },
];
---

<footer style="border-top:2px solid var(--fg);background:var(--bg-page)">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6 sm:py-7 flex flex-col sm:flex-row items-center justify-between gap-4">

    <span class="font-mono font-bold text-[14px]" style="color:var(--accent-text)">~/ihabnk</span>

    <span class="font-mono text-[11px]" style="color:var(--fg-muted)">© 2026</span>

    <div class="flex items-center gap-3">
      {socials.map(s => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.label}
          title={s.label}
          class="social-icon group relative inline-flex items-center justify-center w-9 h-9 rounded-[4px] transition-all duration-150"
        >
          <svg
            class="w-[18px] h-[18px] transition-transform duration-150 group-hover:scale-110"
            viewBox={s.viewBox}
            fill="currentColor"
            aria-hidden="true"
            set:html={s.svg}
          />
        </a>
      ))}
    </div>

  </div>
</footer>

<style>
  .social-icon {
    color: var(--fg-muted);
    border: 1.5px solid transparent;
  }
  .social-icon:hover {
    color: var(--accent-text);
    border-color: var(--accent);
    background: var(--accent-chip);
  }
  .social-icon::after {
    /* Tooltip with platform name on hover */
    content: attr(aria-label);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(2px);
    padding: 4px 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--bg-page);
    background: var(--fg);
    border-radius: 3px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .social-icon:hover::after,
  .social-icon:focus-visible::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>
