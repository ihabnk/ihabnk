---
import { langColor } from '../lib/github';
import type { Repo } from '../lib/github';

interface Props { repo: Repo; }
const { repo } = Astro.props;
const color = langColor(repo.language);
---

<article
  class="card-brutal card-shine group flex flex-col p-5"
  style="background:var(--bg-card)"
>
  <!-- Name + GitHub link -->
  <div class="flex items-start justify-between gap-3 mb-2">
    <h3 class="font-mono font-bold text-[15px] truncate leading-snug" style="color:var(--accent-text)">
      <a
        href={repo.html_url}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:underline underline-offset-4"
        style="text-decoration-color:var(--accent)"
      >{repo.name}</a>
    </h3>
    <a
      href={repo.html_url}
      target="_blank"
      rel="noopener noreferrer"
      class="shrink-0 mt-0.5 transition-opacity duration-200 hover:opacity-70"
      style="color:var(--fg-muted)"
      aria-label="Open on GitHub"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
      </svg>
    </a>
  </div>

  <!-- Description -->
  <p class="text-xs leading-relaxed mb-4 flex-1 line-clamp-2" style="color:var(--fg-mid)">
    {repo.description ?? <span class="italic" style="color:var(--fg-muted)">No description</span>}
  </p>

  <!-- Topics -->
  {repo.topics?.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mb-3">
      {repo.topics.slice(0, 3).map(topic => (
        <span
          class="font-mono text-[9px] px-1.5 py-0.5 rounded-full"
          style="border:1px solid var(--border);color:var(--fg-muted)"
        >{topic}</span>
      ))}
    </div>
  )}

  <!-- Footer: lang + stars -->
  <div
    class="flex items-center gap-3 mt-auto pt-3"
    style="border-top:1px dashed var(--border)"
  >
    {repo.language && (
      <span class="flex items-center gap-1.5 font-mono text-[10px]" style="color:var(--fg-muted)">
        <span class="w-[9px] h-[9px] rounded-full flex-shrink-0 pulse-dot" style={`background:${color}`}></span>
        {repo.language}
      </span>
    )}

    <span class="flex items-center gap-1 font-mono text-[10px]" style="color:var(--fg-muted)">
      ★ {repo.stargazers_count}
    </span>

    {repo.forks_count > 0 && (
      <span class="font-mono text-[10px]" style="color:var(--fg-muted)">⑂ {repo.forks_count}</span>
    )}

    {repo.homepage && (
      <a
        href={repo.homepage}
        target="_blank"
        rel="noopener noreferrer"
        class="ms-auto flex items-center gap-1 font-mono text-[10px] transition-opacity duration-200 hover:opacity-70"
        style="color:var(--accent-text)"
      >
        Live
        <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
        </svg>
      </a>
    )}
  </div>
</article>
