---
import { useTranslations, languages, localePrefix } from '../i18n/ui';
import type { Language } from '../i18n/ui';

interface Props { lang: Language; }

const { lang } = Astro.props;
const t = useTranslations(lang);
const otherLang: Language = lang === 'ar' ? 'en' : 'ar';
const p = localePrefix(lang);
const otherP = localePrefix(otherLang);
const pathname = Astro.url.pathname;

const navLinks = [
  { href: `${p}/blog`,      label: t('nav.blog') },
  { href: `${p}/#projects`, label: t('nav.projects') },
  { href: `${p}/about`,     label: t('nav.about') },
];

function isActive(href: string) {
  const path = href.split('#')[0];
  return pathname === path || pathname === path + '/' || pathname.startsWith(path + '/');
}
---

<header
  id="site-header"
  class="sticky top-0 z-50 transition-shadow duration-300"
  style="background:var(--nav-bg);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:2px solid var(--fg)"
>
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-[72px]">

    <!-- Logo -->
    <a
      href={`${p}/`}
      class="font-mono font-bold text-[15px] tracking-[0.05em] transition-opacity duration-200 hover:opacity-75"
      style="color:var(--accent-text)"
    >~/</a>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class="nav-link font-mono text-[13px] px-3 py-2 transition-colors duration-200"
          style="color:var(--fg-muted)"
        >{link.label}</a>
      ))}

      <!-- Social icons (desktop) -->
      <div class="flex items-center ms-2 gap-1">
        <a
          href="https://github.com/ihabnk"
          target="_blank"
          rel="noopener noreferrer"
          class="p-[6px] rounded-[4px] transition-opacity duration-200 hover:opacity-70"
          style="color:var(--fg-muted)"
          aria-label="GitHub"
        >
          <svg class="w-[15px] h-[15px]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/ihabnk"
          target="_blank"
          rel="noopener noreferrer"
          class="p-[6px] rounded-[4px] transition-opacity duration-200 hover:opacity-70"
          style="color:var(--fg-muted)"
          aria-label="LinkedIn"
        >
          <svg class="w-[15px] h-[15px]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>

      <!-- Theme toggle -->
      <button
        class="theme-toggle ms-1 p-[5px] rounded-[4px] transition-colors duration-200"
        style="background:var(--bg-card);border:1px solid var(--border);color:var(--fg-muted)"
        aria-label="Toggle theme"
        aria-pressed="false"
      >
        <svg class="icon-moon w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/>
        </svg>
        <svg class="icon-sun w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
        </svg>
      </button>

      <!-- Lang toggle -->
      <a
        href={`${otherP}/`}
        class="font-mono font-bold text-[12px] ms-1 px-[9px] py-[5px] rounded-[4px] transition-colors duration-200"
        style="background:var(--bg-card);border:1px solid var(--border);color:var(--fg-muted);letter-spacing:0.04em"
      >{languages[lang]}</a>
    </div>

    <!-- Mobile controls -->
    <div class="flex sm:hidden items-center gap-2">
      <button
        class="theme-toggle p-[5px] rounded-[4px] transition-colors duration-200"
        style="background:var(--bg-card);border:1px solid var(--border);color:var(--fg-muted)"
        aria-label="Toggle theme"
        aria-pressed="false"
      >
        <svg class="icon-moon w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/>
        </svg>
        <svg class="icon-sun w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
        </svg>
      </button>

      <a
        href={`${otherP}/`}
        class="font-mono font-bold text-[12px] px-2 py-[5px] rounded-[4px] transition-colors duration-200"
        style="background:var(--bg-card);border:1px solid var(--border);color:var(--fg-muted)"
      >{languages[lang]}</a>

      <button
        id="mobile-menu-btn"
        class="p-1 transition-colors"
        style="color:var(--fg-muted)"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="icon-open"  class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
      </button>
    </div>

  </nav>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="sm:hidden hidden"
    style="border-top:2px solid var(--fg);background:var(--bg-page)"
  >
    <div class="max-w-5xl mx-auto px-4 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class="font-mono text-[14px] px-3 py-2.5 rounded-[4px] transition-colors duration-150"
          style="color:var(--fg-muted)"
        >{link.label}</a>
      ))}
      <!-- Mobile social links -->
      <div class="flex gap-4 px-3 pt-3 mt-2" style="border-top:1px solid var(--border)">
        <a href="https://github.com/ihabnk" target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-1.5 font-mono text-[11px] transition-opacity hover:opacity-70"
           style="color:var(--fg-muted)">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="https://linkedin.com/in/ihabnk" target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-1.5 font-mono text-[11px] transition-opacity hover:opacity-70"
           style="color:var(--fg-muted)">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn    = document.getElementById('mobile-menu-btn')!;
  const menu   = document.getElementById('mobile-menu')!;
  const iconO  = document.getElementById('icon-open')!;
  const iconC  = document.getElementById('icon-close')!;
  const header = document.getElementById('site-header')!;

  btn?.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!open));
    iconO.classList.toggle('hidden');
    iconC.classList.toggle('hidden');
  });

  window.addEventListener('scroll', () => {
    header.classList.toggle('shadow-[0_2px_0_var(--fg)]', window.scrollY > 10);
  }, { passive: true });

  document.querySelectorAll<HTMLButtonElement>('.theme-toggle').forEach(toggle => {
    toggle.addEventListener('click', () => {
      const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      document.querySelectorAll<HTMLButtonElement>('.theme-toggle').forEach(b =>
        b.setAttribute('aria-pressed', String(next === 'dark'))
      );
    });
  });
</script>
