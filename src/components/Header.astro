---
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/',        label: 'Home' },
  { href: '/blog',    label: 'Articles' },
  { href: '/reviews', label: 'Reviews' },
  { href: '/about',   label: 'About' },
];

function isActive(href: string) {
  if (href.includes('#')) return false;
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname === href || pathname === href + '/' || pathname.startsWith(href + '/');
}
---

<header
  id="site-header"
  class="sticky top-0 z-50 site-header"
  style="background:var(--nav-bg);border-bottom:2px solid var(--fg);padding-top:constant(safe-area-inset-top);padding-top:env(safe-area-inset-top,0px)"
>
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-[64px]">

    <!-- LEFT: logo -->
    <a
      href="/"
      class="font-mono font-bold text-[15px] sm:text-[17px] tracking-[0.05em] transition-opacity duration-200 hover:opacity-75 shrink-0"
      style="color:var(--accent-text)"
    >~/ihabnk</a>

    <!-- MIDDLE: nav links (centered via space-between) -->
    <div class="hidden sm:flex items-center gap-7">
      {navLinks.map(link => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class="nav-link font-mono text-[13px] py-2 transition-colors duration-150 hover:opacity-100"
          style={isActive(link.href)
            ? 'color:var(--accent-text);font-weight:700'
            : 'color:var(--fg-muted);font-weight:400'}
        >{link.label}</a>
      ))}
    </div>

    <!-- RIGHT: theme toggle (desktop) -->
    <div class="hidden sm:flex items-center gap-2 shrink-0">
      <ThemeToggle />
    </div>

    <!-- RIGHT: mobile controls -->
    <div class="flex sm:hidden items-center gap-2 shrink-0">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        class="p-2 -mr-2 transition-colors"
        style="color:var(--fg-muted)"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="icon-open"  class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
      </button>
    </div>

  </nav>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="sm:hidden mobile-drawer"
    style="border-top:2px solid var(--fg);background:var(--bg-page)"
  >
    <div class="max-w-5xl mx-auto px-4 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class="font-mono text-[14px] px-4 py-3 rounded-[4px] transition-colors duration-150"
          style={isActive(link.href)
            ? 'color:var(--accent-text);font-weight:700;border-left:3px solid var(--accent);background:var(--accent-chip)'
            : 'color:var(--fg);font-weight:400'}
        >{link.label}</a>
      ))}
    </div>
  </div>
</header>

<style>
  .mobile-drawer { max-height: 0; overflow: hidden; transition: max-height 0.25s ease; }
  .mobile-drawer.open { max-height: 400px; }

  .site-header {
    will-change: transform;
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1),
                background-color 0.2s ease,
                box-shadow 0.2s ease;
  }

  /* Inactive nav links: subtle hover affordance to confirm interactivity */
  .nav-link:not([aria-current='page']):hover {
    color: var(--fg) !important;
  }

  /* Scroll-aware: only translate on mobile so desktop never hides.
     Hide fully via -100%; the body::before cap (z=51) keeps the iOS
     status-bar strip opaque regardless of header position. */
  @media (max-width: 639px) {
    .site-header.is-hidden { transform: translateY(-100%); }
  }
  /* If the mobile drawer is open, never hide the header even if scrolling */
  .site-header:has(#mobile-menu.open) { transform: none !important; }
</style>

<script>
  // Everything below is delegated on the document so handlers survive
  // ClientRouter view transitions (which swap the header DOM in-place).
  const w = window as Window & { __navInited?: boolean };
  if (!w.__navInited) {
    w.__navInited = true;

    // Mobile menu toggle
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      const btn    = target?.closest('#mobile-menu-btn');
      if (!btn) return;
      const menu  = document.getElementById('mobile-menu');
      const iconO = document.getElementById('icon-open');
      const iconC = document.getElementById('icon-close');
      if (!menu) return;
      const open = menu.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
      iconO?.classList.toggle('hidden', open);
      iconC?.classList.toggle('hidden', !open);
    });

    // Theme toggle
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      const toggle = target?.closest<HTMLButtonElement>('.theme-toggle');
      if (!toggle) return;
      const current = document.documentElement.getAttribute('data-theme') ?? 'light';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      toggle.classList.add('spin');
      setTimeout(() => toggle.classList.remove('spin'), 250);
      document.querySelectorAll<HTMLButtonElement>('.theme-toggle').forEach(b =>
        b.setAttribute('aria-pressed', String(next === 'dark'))
      );
    });

    // Scroll-aware navbar: hide on scroll down, reveal on scroll up.
    const SCROLL_THRESHOLD = 10;   // ignore jitter under 10px
    const REVEAL_AT_TOP    = 80;   // always show near the top
    let lastY = window.scrollY;
    let ticking = false;

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const header = document.getElementById('site-header');
        const y      = window.scrollY;
        const dy     = y - lastY;

        if (header) {
          header.classList.toggle('is-scrolled', y > 200);

          if (Math.abs(dy) >= SCROLL_THRESHOLD) {
            if (y < REVEAL_AT_TOP) {
              header.classList.remove('is-hidden');
            } else if (dy > 0) {
              header.classList.add('is-hidden');
            } else {
              header.classList.remove('is-hidden');
            }
            lastY = y;
          }
        }
        ticking = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    // After a view transition, the new page starts at the top — reset state.
    document.addEventListener('astro:after-swap', () => {
      lastY = window.scrollY;
      document.getElementById('site-header')?.classList.remove('is-hidden');
    });
  }
</script>
