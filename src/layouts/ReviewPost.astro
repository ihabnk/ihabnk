---
import Base from './Base.astro';
import ReviewHero from '../components/ReviewHero.astro';
import ReviewToc from '../components/ReviewToc.astro';
import Verdict from '../components/Verdict.astro';
import ProsCons from '../components/ProsCons.astro';
import ScoreBreakdown from '../components/ScoreBreakdown.astro';

interface TocItem { label: string; anchor: string }

interface Props {
  title: string;
  description?: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  kind: 'review' | 'comparison';
  tools: string[];
  verdict?: string;
  bestFor?: string;
  rating?: number;
  pros?: string[];
  cons?: string[];
  scores?: Record<string, number>;
  toc?: TocItem[];
  readingTimeMin: number;
}

const {
  title, description, date, updated, tags,
  kind, tools, verdict, bestFor, rating,
  pros, cons, scores, toc, readingTimeMin,
} = Astro.props;

const articleUrl = new URL(Astro.url.pathname, 'https://ihabnk.org').href;
---

<Base {title} {description}>

  <!-- Reading progress bar (same treatment as BlogPost) -->
  <div
    id="reading-progress"
    class="fixed left-0 right-0 h-[3px] z-40 scale-x-0 transition-none"
    style="top:calc(64px + env(safe-area-inset-top, 0px));transform-origin:left;background:var(--accent)"
    aria-hidden="true"
  ></div>

  <div class="article-col">

    <!-- Top row: Back -->
    <div class="flex items-center mb-6">
      <a
        href="/reviews"
        class="ghost-btn group inline-flex items-center gap-2 font-mono text-[12px] px-4 h-10 rounded-[4px]"
      >
        <span class="transition-transform duration-200 group-hover:-translate-x-0.5">←</span>
        Reviews
      </a>
    </div>

    <ReviewHero
      {title}
      {description}
      {date}
      {updated}
      {tags}
      {kind}
      {tools}
      {rating}
      {readingTimeMin}
      {articleUrl}
    />

    {verdict && <Verdict text={verdict} bestFor={bestFor} />}

    {toc && toc.length > 0 && <ReviewToc items={toc} />}

    {scores && Object.keys(scores).length > 0 && (
      <ScoreBreakdown {scores} />
    )}

    {(pros?.length || cons?.length) && (
      <ProsCons pros={pros ?? []} cons={cons ?? []} />
    )}

    <!-- Editorial body -->
    <div id="article-body" class="article-body prose max-w-none">
      <slot />
    </div>

    <!-- Footer -->
    <footer class="mt-16 pt-8" style="border-top:2px solid var(--fg)">
      <a
        href="/reviews"
        class="group inline-flex items-center gap-2 font-mono text-sm transition-colors duration-200"
        style="color:var(--fg-muted)"
      >
        <span class="transition-transform duration-200 group-hover:-translate-x-0.5">←</span>
        Back to reviews
      </a>
    </footer>

  </div>

</Base>

<script>
  (() => {
    type W = Window & { __blogPostInited?: boolean };
    const w = window as W;

    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('in-view'); io.unobserve(e.target); }
      }),
      { threshold: 0.08 }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    if (w.__blogPostInited) return;
    w.__blogPostInited = true;

    window.addEventListener('scroll', () => {
      const bar = document.getElementById('reading-progress');
      if (!bar) return;
      const doc   = document.documentElement;
      const total = doc.scrollHeight - doc.clientHeight;
      bar.style.transform = `scaleX(${total > 0 ? window.scrollY / total : 0})`;
    }, { passive: true });
  })();
</script>
