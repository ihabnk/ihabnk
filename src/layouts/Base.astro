---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TTSBar from '../components/TTSBar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** When set, page is treated as an article: og:type=article, article meta
   *  tags emitted, and an Article/BlogPosting JSON-LD is rendered. */
  article?: {
    published: Date;
    modified?: Date;
    tags?: string[];
    /** "BlogPosting" for /blog/*, "Article" (or "Review") for /reviews/* */
    schemaType?: 'BlogPosting' | 'Article' | 'Review';
  };
}

const {
  title,
  description = 'ihabnk — QA Engineer turned AI Product builder',
  ogImage,
  article,
} = Astro.props;
const pageTitle = title === 'ihabnk' ? 'ihabnk' : `${title} | ihabnk`;
const canonical = new URL(Astro.url.pathname, 'https://ihabnk.org').href;
const ogType = article ? 'article' : 'website';

// Person identity — used for sitewide JSON-LD and as the Article author/publisher.
const person = {
  '@type': 'Person',
  name: 'Ihab NK',
  url: 'https://ihabnk.org',
  sameAs: [
    'https://github.com/ihabnk',
    'https://linkedin.com/in/ihabnk',
    'https://bsky.app/profile/ihabnk.org',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ihabnk',
  url: 'https://ihabnk.org',
  description: 'ihabnk — QA Engineer turned AI Product builder. Articles and reviews on AI quality, evals, and product engineering.',
  author: person,
  publisher: person,
};

const articleSchema = article
  ? {
      '@context': 'https://schema.org',
      '@type': article.schemaType ?? 'BlogPosting',
      headline: title,
      description,
      datePublished: article.published.toISOString(),
      dateModified: (article.modified ?? article.published).toISOString(),
      author: person,
      publisher: person,
      mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
      url: canonical,
      ...(article.tags?.length ? { keywords: article.tags.join(', ') } : {}),
      ...(ogImage ? { image: ogImage } : {}),
    }
  : null;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <!-- iOS standalone / PWA: ensure status-bar insets reach CSS via env() -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <!-- Apply saved theme before paint. Default to light unless user opted into dark. -->
    <script is:inline>
      (() => {
        const apply = () => {
          const t = localStorage.getItem('theme');
          document.documentElement.setAttribute('data-theme', t === 'dark' ? 'dark' : 'light');
        };
        apply();
        if (!window.__themeListenerBound) {
          window.__themeListenerBound = true;
          document.addEventListener('astro:after-swap', apply);
        }
      })();
    </script>
    <ClientRouter />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Ihab NK" />
    <link rel="canonical" href={canonical} />

    <!-- Full favicon family — covers SVG-aware browsers, the auto /favicon.ico
         request, PNG fallbacks, and iOS touch-icon. Multi-source so any cached
         old (Hugo/Blowfish) icon is replaced on next paint. -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="alternate icon" href="/favicon.ico" />

    <!-- Mobile address-bar tint, matched to the warm cream / espresso palette -->
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f5efe6" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)"  content="#150f0b" />

    <!-- RSS — both surfaces SEO + lets readers subscribe -->
    <link rel="alternate" type="application/rss+xml" title="ihabnk — articles & reviews" href="/rss.xml" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="ihabnk" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {article && <meta property="article:published_time" content={article.published.toISOString()} />}
    {article?.modified && <meta property="article:modified_time" content={article.modified.toISOString()} />}
    {article && <meta property="article:author" content="Ihab NK" />}
    {article?.tags?.map(t => <meta property="article:tag" content={t} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Structured data: WebSite always; Article only on /blog/* and /reviews/* -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=IBM+Plex+Mono:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-full flex flex-col antialiased" style="background-color:var(--bg-page);color:var(--fg)">
    <a href="#main-content" class="skip-link">Skip to content</a>

    <!-- Global scroll-progress bar (very thin, above the header) -->
    <div
      id="global-scroll-progress"
      class="fixed left-0 right-0 top-0 h-[2px] z-50 scale-x-0"
      style="transform-origin:left;background:var(--accent);will-change:transform"
      aria-hidden="true"
    ></div>

    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <TTSBar />

    <!-- GSAP + ScrollTrigger orchestration. Bundles via Astro's Vite. -->
    <script>
      import '../scripts/gsap-init';
    </script>

    <!-- Site-wide scroll interactivity: bidirectional reveal + top progress bar.
         Reveal is direction-aware — elements animate in from the same edge they
         scrolled off (down = from below, up = from above).

         Hardening for SPA-style navigation:
           • Re-bind on every Astro navigation event AND on bfcache restore.
           • MutationObserver watches for new `.reveal*` nodes inserted at any
             time (Astro view-transitions, async content, manual injection).
           • Stale `.in-view` / `.from-above` classes are cleared on swap so
             the next page starts fresh. -->
    <script is:inline>
      (() => {
        const w = window;
        if (w.__siteScrollInited) return;
        w.__siteScrollInited = true;

        // Gate the .reveal opacity:0 in CSS until JS confirms it can show them.
        document.documentElement.classList.add('reveal-ready');

        const SELECTOR = '.reveal, .reveal-soft';
        let io = null;
        const seen = new WeakSet(); // elements currently observed

        function onEntries(entries) {
          for (const e of entries) {
            const target = e.target;
            if (e.isIntersecting) {
              target.classList.add('in-view');
            } else {
              target.classList.remove('in-view');
              target.classList.toggle('from-above', e.boundingClientRect.top < 0);
            }
          }
        }

        function ensureObserver() {
          if (io) return io;
          io = new IntersectionObserver(onEntries, {
            threshold: 0.05,
            rootMargin: '-40px 0px -40px 0px',
          });
          return io;
        }

        function observeAll(root) {
          const obs = ensureObserver();
          const scope = root && root.querySelectorAll ? root : document;
          scope.querySelectorAll(SELECTOR).forEach((el) => {
            if (seen.has(el)) return;
            seen.add(el);
            obs.observe(el);
          });
        }

        function rebindAll() {
          // After a view transition the body subtree is replaced — old
          // observations point at dead nodes. Recreate the observer and
          // re-observe everything from a clean resting state.
          if (io) { io.disconnect(); io = null; }
          document.querySelectorAll(SELECTOR).forEach((el) => {
            el.classList.remove('in-view', 'from-above');
          });
          observeAll(document);
        }

        function onScroll() {
          const bar = document.getElementById('global-scroll-progress');
          if (!bar) return;
          const doc = document.documentElement;
          const total = doc.scrollHeight - doc.clientHeight;
          const ratio = total > 0 ? Math.max(0, Math.min(1, window.scrollY / total)) : 0;
          bar.style.transform = 'scaleX(' + ratio + ')';
        }

        // Watch DOM mutations so any later-inserted .reveal element gets observed.
        const mo = new MutationObserver((muts) => {
          for (const m of muts) {
            m.addedNodes.forEach((n) => {
              if (n.nodeType !== 1) return; // element only
              if (n.matches && n.matches(SELECTOR)) {
                if (!seen.has(n)) { seen.add(n); ensureObserver().observe(n); }
              }
              observeAll(n);
            });
          }
        });
        mo.observe(document.body, { childList: true, subtree: true });

        // First-paint binding
        observeAll(document);
        onScroll();

        window.addEventListener('scroll', onScroll, { passive: true });

        // Astro view-transition lifecycle
        document.addEventListener('astro:after-swap', () => {
          const bar = document.getElementById('global-scroll-progress');
          if (bar) bar.style.transform = 'scaleX(0)';
          rebindAll();
          onScroll();
        });
        document.addEventListener('astro:page-load', () => {
          observeAll(document);
          onScroll();
        });

        // Browser back/forward — restoring from bfcache doesn't fire load events
        // but does fire pageshow with persisted=true.
        window.addEventListener('pageshow', (ev) => {
          if (ev.persisted) rebindAll();
          onScroll();
        });
        window.addEventListener('hashchange', onScroll);
      })();
    </script>
  </body>
</html>
