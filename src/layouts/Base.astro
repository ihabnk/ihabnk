---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TTSBar from '../components/TTSBar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'ihabnk — QA Engineer turned AI Product builder', ogImage } = Astro.props;
const pageTitle = title === 'ihabnk' ? 'ihabnk' : `${title} | ihabnk`;
const canonical = new URL(Astro.url.pathname, 'https://ihabnk.org').href;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <!-- iOS standalone / PWA: ensure status-bar insets reach CSS via env() -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <!-- Apply saved theme before paint. Default to light unless user opted into dark. -->
    <script is:inline>
      (() => {
        const apply = () => {
          const t = localStorage.getItem('theme');
          document.documentElement.setAttribute('data-theme', t === 'dark' ? 'dark' : 'light');
        };
        apply();
        if (!window.__themeListenerBound) {
          window.__themeListenerBound = true;
          document.addEventListener('astro:after-swap', apply);
        }
      })();
    </script>
    <ClientRouter />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ihabnk" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=IBM+Plex+Mono:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-full flex flex-col antialiased" style="background-color:var(--bg-page);color:var(--fg)">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <TTSBar />
  </body>
</html>
