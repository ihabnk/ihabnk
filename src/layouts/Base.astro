---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import type { Language } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang: Language;
  ogImage?: string;
}

const { title, description = 'ihabnk — QA Engineer turning AI Product builder', lang, ogImage } = Astro.props;
const dir = lang === 'ar' ? 'rtl' : 'ltr';
const pageTitle = title === 'ihabnk' ? 'ihabnk' : `${title} | ihabnk`;
const canonical = new URL(Astro.url.pathname, 'https://ihabnk.org').href;
---

<!doctype html>
<html lang={lang} dir={dir} class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=IBM+Plex+Mono:wght@400;700&family=Inter:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-full flex flex-col antialiased" style="background-color:var(--bg-page);color:var(--fg)">
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Buy Me a Coffee floating widget -->
    <script
      is:inline
      data-name="BMC-Widget"
      data-cfasync="false"
      src="https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js"
      data-id="ihabnk"
      data-description=""
      data-message=""
      data-color="#c8841a"
      data-position="Right"
      data-x_margin="18"
      data-y_margin="18"
    ></script>
  </body>
</html>
