---
import Base from './Base.astro';
import ArticleHero from '../components/ArticleHero.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
}

const { title, description, date, tags } = Astro.props;
const articleUrl    = new URL(Astro.url.pathname, 'https://ihabnk.org').href;
const linkedInShare = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(articleUrl)}`;
const twitterShare  = `https://twitter.com/intent/tweet?url=${encodeURIComponent(articleUrl)}&text=${encodeURIComponent(title)}`;
---

<Base {title} {description}>

  <!-- Reading progress bar (sits flush below the header, including notch inset) -->
  <div
    id="reading-progress"
    class="fixed left-0 right-0 h-[3px] z-40 scale-x-0 transition-none"
    style="top:calc(64px + env(safe-area-inset-top, 0px));transform-origin:left;background:var(--accent)"
    aria-hidden="true"
  ></div>

  <div class="article-col">

    <!-- Top row: Back link + Listen button (matches standalone PostScreen) -->
    <div class="flex items-center justify-between flex-wrap gap-3 mb-6">
      <a
        href="/blog"
        class="ghost-btn group inline-flex items-center gap-2 font-mono text-[12px] px-4 h-10 rounded-[4px]"
      >
        <span class="transition-transform duration-200 group-hover:-translate-x-0.5">←</span>
        Articles
      </a>

      <button
        id="tts-trigger"
        class="listen-btn"
        aria-label="Listen to article"
      >
        <span class="listen-dot"></span>
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 18v-6a9 9 0 0 1 18 0v6"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
        </svg>
        <span id="tts-trigger-label">Listen to article</span>
      </button>
    </div>

    <ArticleHero {title} {description} {tags} {date} {articleUrl} />

    <!-- Article body -->
    <div id="article-body" class="article-body prose max-w-none">
      <slot />
    </div>

    <!-- Article footer -->
    <footer class="mt-16 pt-8" style="border-top:2px solid var(--fg)">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <a
          href="/blog"
          class="group inline-flex items-center gap-2 font-mono text-sm transition-colors duration-200"
          style="color:var(--fg-muted)"
        >
          <span class="transition-transform duration-200 group-hover:-translate-x-0.5">←</span>
          Back to articles
        </a>
        <div class="flex gap-3">
          <a href={twitterShare} target="_blank" rel="noopener noreferrer"
             class="font-mono text-xs transition-colors duration-200" style="color:var(--fg-muted)">
            Share ↗
          </a>
          <a href={linkedInShare} target="_blank" rel="noopener noreferrer"
             class="font-mono text-xs transition-colors duration-200" style="color:var(--fg-muted)">
            LinkedIn ↗
          </a>
        </div>
      </div>
    </footer>

  </div>

</Base>

<script>
  (() => {
    type W = Window & { __blogPostInited?: boolean };
    const w = window as W;

    // Always re-observe reveal targets for the current page.
    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('in-view'); io.unobserve(e.target); }
      }),
      { threshold: 0.08 }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    // Reading-progress listener: install once on the window so navigations
    // don't stack up duplicate scroll handlers.
    if (w.__blogPostInited) return;
    w.__blogPostInited = true;

    window.addEventListener('scroll', () => {
      const bar = document.getElementById('reading-progress');
      if (!bar) return;
      const doc   = document.documentElement;
      const total = doc.scrollHeight - doc.clientHeight;
      bar.style.transform = `scaleX(${total > 0 ? window.scrollY / total : 0})`;
    }, { passive: true });
  })();
</script>
