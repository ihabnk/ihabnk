# ──────────────────────────────────────────────
# BeautyOnCall — Backend Environment Variables
# Copy this file to .env and fill in every value
# ──────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database (Prisma connection string)
DATABASE_URL=file:./dev.db

# Auth — JWT
JWT_SECRET=
JWT_REFRESH_SECRET=

# Twilio (SMS / OTP)
TWILIO_SID=
TWILIO_AUTH_TOKEN=

# Supabase Storage (media uploads)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=

# Client URL (CORS origin)
CLIENT_URL=http://localhost:3001
