# ──────────────────────────────────────────────
# BeautyOnCall — Backend Environment Variables
# Copy this file to .env and fill in every value
# ──────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database (Prisma connection string)
DATABASE_URL=file:./dev.db

# Auth — JWT
JWT_SECRET=
JWT_REFRESH_SECRET=

# Twilio (SMS / OTP)
TWILIO_SID=
TWILIO_AUTH_TOKEN=

# Stripe
STRIPE_SECRET_KEY=

# AWS S3 (media uploads)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET_NAME=

# Client URL (CORS origin)
CLIENT_URL=http://localhost:3001

# Google Maps (geocoding, existing integration)
GOOGLE_MAPS_API_KEY=
